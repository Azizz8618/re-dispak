***************************************************
* ФЗ15 – ПРОВЕРКА НЕИСПРАВНОСТИ МД И ЗАНЯТОСТИ
* КАНАЛА ПЕРЕД ВЫДАЧЕЙ ЗАКАЗА.
* ИСПОЛЬЗУЕТ: М16 (НАПРАВЛЕНИЕ), М4 (УСТРОЙСТВО),
* М3 (ЛИНИЯ), М14 (ЗАКАЗ).
***************************************************
ФЗ15    СЧ      МДНЕИС-3(М16)    , загрузить слово неисправностей МД
        ИЛИ     Е32(М4)         , установить бит устройства (М4 – номер МД)
        НТЖ     Е32(М4)         , сбросить этот бит (снять неисправность)
        ЗП      МДНЕИС-3(М16)   , обновить шкалу неисправностей
        СЧ      ЗАНКМД-3(М16)   , загрузить занятость каналов МД
        И       Е48             , проверить 48-й разряд
        ПЕ      Д               , если =1 – направление занято другой машиной
        счи     М3              , иначе взять номер линии (М3)
        сда     64-3            , сдвинуть для сравнения с кодом линии
        нтж     ЗАНКМД-3(М16)   , сравнить с занятостью канала
        по      Д1              , совпадает – заказ к открытой линии
        пб      Д3              , иначе – заказ к неоткрытой линии
*
Д       СЧ      ОЖОСВ-3(М16)    , загрузить слово ожидания освобождения
        ПЕ      Д3              , если не 0 – запрос к напр. уже выдан
        СЧ      ОЧКУСД-1(М14)   , взять управляющее слово очереди заказов
        пб      дс              , переход к формированию запроса
*
пс      уиа     '2003'          , блокировка прерываний
        сч      ШЗПОМД          , загрузить шкалу задержки обмена МД
        нтж     РАЗЛ            , сбросить флаг "различный"
        или     E40             , установить бит 40 (признак занятости)
        зп      ШЗПОМД          , обновить шкалу
        сч      ОЖОСВ-3(М16)    , проверить ожидание освобождения
        пе      Д3              , если есть – выход
        счи     М3              , взять номер линии
        сда     64-39           , сдвинуть для поля номера линии
        или     E8              , добавить признак "запрос"
дс      зп      ОЖОСВ-3(М16)    , сохранить запрос к направлению
        пв      ЗАПРОС(М11)     , вызов процедуры ЗАПРОС (выдача в КМД)
        сч      МГРП            , загрузить маску ГРП
        или     E32(М16)        , установить бит прерывания от напр.
        зп      МГРП            , обновить маску
        рег     '36'            , записать маску ГРП в регистр
        уиа     '3'             , разрешить прерывания
        пб      Д3              , переход к завершению
*
Д1      сч      ШОЧНМД-3(М16)   , загрузить шкалу очереди к напр.
        и       Е48-1(М14)      , проверить бит текущего заказа
        по      ДИ              , если 0 – заказ не в очереди, обход
        сч      ОЧКУСД-1(М14)   , взять управляющее слово заказа
        мода                    , сброс модификации
        пв      МДНАП(М2)       , вызов МДНАП: инвертировать N МД ->М15
*                               , N напр., N МД -> М1
        сч      ЗАНМД-3(М16)    , загрузить занятость накопителей МД
        и       E32(М4)         , проверить бит устройства
        пе      Д3              , устройство занято – выход
        пв      ПОДОБМ(М11)     , выдать заказ в КМД (подобм)
        сч      ЯМГРП           , взять накопленную маску ГРП
        пв      ТВ67(М15)       , гасить 29(28) разряд ГРП, открыть маску
        сч                      , очистить сумматор
        зп      ЯМГРП           , обнулить накопленную маску
Д3      сч                      , очистить сумматор
        зп      блоз            , сбросить блокировку ошибок
        сч      E40             , загрузить бит 40
Д3А1    уиа     '2003'          , блокировка прерываний
        нтж     ШЗПОМД          , сбросить бит 40 в шкале задержки
        зп      ШЗПОМД          , обновить шкалу (освободить канал)
Д33     и       Е48Е47          , проверить биты 48-47 (есть ли прерывание?)
        по      Д4А             , если нет – переход к анализу
        нед     E2              , найти номер старшего бита (напр.)
        уи      М16             , М16 = номер направления прерывания
        пб      ВХД             , переход в обработчик ВХД
***************************************************
* Д5 – АНАЛИЗ ЗАВЕРШЕНИЯ ОБМЕНА С МД.
* РАЗБИРАЕТ ПРИЧИНУ ПРЕРЫВАНИЯ (ПОДВОД ИЛИ ОБМЕН),
* ВЫЗЫВАЕТ ОБРАБОТЧИКИ ОШИБОК И ПОВТОРНЫХ ЗАКАЗОВ.
* ИСПОЛЬЗУЕТ: М16 (НАПРАВЛЕНИЕ), М14 (ЗАКАЗ),
* М4 (УСТРОЙСТВО), М15 (НОМЕР УСТР.), М3 (ЛИНИЯ),
* М11 (АДРЕС ВОЗВРАТА), М2 (ТИП ОБМЕНА).
***************************************************
Д5      сч      СОД-3(М16)      , загрузить слово состояния обмена (СОД)
        и       Е24П17          , выделить биты занятости направления
        по      Д5Д             , если не занято обменом – к Д5Д
        сда     64+16           , сдвинуть для выделения поля "подвод"
        и       ЯПРМД-3(М16)    , проверить шкалу завершённых прерываний
        по      Д8А             , если нет завершённых – к Д8А
Д5Д     сч      ЯПРМД-3(М16)    , загрузить шкалу прерываний МД
        по      Д7              , если пуста – к Д7 (нет событий)
        нед     П7              , найти старший бит (номер устройства)
        нтж     П7              , преобразовать в номер 0..7
        уиа     обрпр(М2)       , адрес обработчика обрпр в М2
        пв      МДНАПС(М11)     , вызов МДНАПС: формирование М1, М15, М3
        сч      типош-3(М16)    , загрузить тип ошибки направления
        по      д5в             , если 0 – заказ выполнен без ошибок
        нтж     E1              , проверить бит 1 (ошибка чтения?)
        пе      обрнев          , если не 0 – переход к обрнев
д5г     уиа     Д5(М11)         , адрес возврата = Д5
        пб      ПОДОБМ          , выдать повторный заказ в НМД
д5в     уиа     Д7(М11)         , адрес возврата = Д7
        пб      ВЫБРЗК          , выбросить заказ из очереди
*
***************************************************
* д5и – ОПРЕДЕЛЕНИЕ НОМЕРА ЗАКАЗА
* И ПОСТАНОВКА ЕГО В КОНЕЦ ОЧЕРЕДИ.
* ИСПОЛЬЗУЕТ: М1, М16, М14, М2, М10.
***************************************************
д5и     уиа     опзак(М2)       , адрес подпрограммы опзак
ОПРЗАК  сч      ШОЧМД(М1)       , загрузить шкалу очереди к устройству
        и       ШОЧНМД-3(М16)   , проверить совпадение с очередью напр.
        и       СИСТ            , выделить только системные заказы
        пе      ОПРЗА           , если есть – к ОПРЗА
        сч      ШОЧМД(М1)       , иначе повторить без СИСТ
        и       ШОЧНМД-3(М16)
ОПРЗА   нед                     , найти старший бит (номер заказа)
        уи      М14             , сохранить в М14
        пб      (М2)            , возврат
*
опзак   уиа     -74(М2)         , счётчик цикла: -74 (размер очереди?)
        пв      ДВОЧ(М10)       , вызов ДВОЧ (сдвиг очереди)
        сч      СЧЗАКД          , загрузить счётчик заказов
        уи      М14             , сохранить номер последнего заказа
        сч      РЯД1            , взять адресную информацию
        зп      ОЧЛИСД-1(М14)   , сохранить в очереди листов
        сч      РЯД2            , взять управляющее слово
        зп      ОЧКУСД-1(М14)   , сохранить в очереди КУСов
        уиа     Д7(М10)         , адрес возврата = Д7
        пб      зкоч            , переход к постановке в очередь
*
д5а     сч      типош-3(М16)    , проверить тип ошибки
        по      д5и             , если 0 – заказ в конец очереди
Д7      сч      СОД-3(М16)      , загрузить СОД направления
        пе      Д8              , если не 0 – ещё не все заказы обработаны
        сч      ДАЙГОТ-3(М16)   , проверить шкалу готовности
        по      Д7В             , если 0 – к Д7В
ОПРГД   сч      ЗАНКМД-3(М16)   , загрузить занятость каналов МД
        сда     64+3            , выделить номер линии (М3)
        и       П3
        уи      М3
        сч      СОД-3(М16)      , проверить поле подвода в СОД
        и       П377
        по      НПР             , если 0 – нет подвода
        сч                      , иначе очистить
        зп      ДАЙГОТ-3(М16)   , сбросить готовность
НПР     сч      ДАЙГОТ-3(М16)   , проверить шкалу готовности устройств
        и       Е32П25(М3)      , для данной линии
        по      Д7В             , если нет готовых – к Д7В
*
        АПУ     (&К71).ДА       , если К71 – спец. обработка
        АПБ     .НЕТ
.ДА     АНОП
нпр1    сч      дготк7          , загрузить адрес перехода
        пб      дтпро           , переход к тесту прерываний (МОТТ)
дготк7  конд    A(*+1)          , адрес возврата
.НЕТ    АНОП
*
        мод     ЗАВ             , модификация по флагу завершения
        уиа     (М7)            , М7 = 0 (сброс)
        сч      Е32П25(М3)      , маска устройств линии
        и       НОМРМД-3(М16)   , проверить рабочие устройства
        или     РМД-3(М16)      , добавить флаги готовности
        зп      РМД-3(М16)      , обновить регистр масок диска
        сч      КНАПР-1(М3)     , загрузить код направления
        уи      М6              , М6 = начальный номер устройства
        уиа     '3'             , разрешить прерывания
        уиа     -7(М13)         , цикл по 8 устройствам направления
*
        АПУ     (&К71).ДА1      , если К71 – свой блок
        АПБ     .НЕТ1
.ДА1    АНОП
нпр2    сч      НОМРМД-3(М16)   , загрузить рабочие устройства
        и       E32(М6)         , проверить конкретное устройство
        по      д7б             , если не рабочее – к д7б
        сч      E1(М13)         , взять маску ошибки
        мода                    , сброс модификации
*
.НЕТ1   АНОП
        АПУ     (&К71).ДА2      , если К71 – альтернатива
д7а     сч      Е8+7(М13)       , загрузить маску открытия для устройства
.ДА2    АНОП
        пв      открмд(М10)     , открыть маску устройства в КМД
        мода                    , сброс модификации
        пв      счрс(М10)       , чтение регистра состояния
        и       E9              , проверить бит "готовность диска"
        по      д7б             , если 0 – не готов, к д7б
        сч      E32(М6)         , взять бит устройства
        нтж     РМД-3(М16)      , сбросить признак "не готов"
        зп      РМД-3(М16)      , обновить регистр (1 – не готов, 0 – готов)
д7б     слиа    1(М6)           , следующий номер устройства
*
        АПУ     (&К71).ДА3      , если К71 – свой цикл
        цикл    д7а(М13)        , цикл по 8 устройствам
        АПБ     .НЕТ2
.ДА3    АНОП
        пв      опргд1(М10)     , вызов опргд1 (проверка удалённого МД)
.НЕТ2   АНОП
        сч      ДАЙГОТ-3(М16)   , обновить шкалу готовности
        или     Е32П25(М3)      , учесть все устройства линии
        нтж     Е32П25(М3)
        зп      ДАЙГОТ-3(М16)
        сч      РМД-3(М16)      , сравнить текущую готовность
        нтж     РМД1-3(М16)     , с предыдущей
        или     ВЫК-3(М16)      , учесть маску выключенных
        и       Е32П25(М3)      , выделить только устройства линии
        и       НОМРМД-3(М16)   , и только рабочие
        уиа     3(М5)           , признак для вызова обработчика
        пе      вызав           , если есть изменения – к вызав
        сч      ЗАВ             , проверить флаг завершения
        пе      НОВД            , если не 0 – к НОВД
        счи     М16             , проверить номер направления
        и       E3
        пе      опи             , если не 0 – к опи
        сч      НОМРМД+1        , обновить ДАЙГОТ для второго направления
        зп      ДАЙГОТ+1
опи     сч      НЗ-3(М16)       , проверить наличие заказов на напр.
        пе      опс1            , если есть – к опс1
Д7В     сч      ЗАНКМД-3(М16)   , загрузить занятость канала
        сда     64+3            , выделить линию
        уи      М3
*
        АПУ     (&К71).ДА4      , если К71 – своё освобождение
        АПБ     .НЕТ3
        пв      ОСВМД(М16)      , освобождение направления (штатное)
.ДА4    АНОП
        пв      тмдоб7(М6)      , К-71: освобождение направления
.НЕТ3   АНОП
        сч      ЗАНКМД-3(М16)   , проверить освобождение направления
        и       E48
        пе      Д73             , если свободно – к Д73
        сч      ШОЧЛ(М3)        , проверить очередь к линии
        и       ШОЧНМД-3(М16)
        по      Д9              , если нет заказов – к Д9
        и       СИСТ            , проверить системные заказы
        пе      д7вг
        сч      ШОЧЛ(М3)        , повторить без СИСТ
        и       ШОЧНМД-3(М16)
д7вг    нед                     , найти старший заказ
        уи      М14
        сч      ОЧКУСД-1(М14)   , взять его управляющее слово
        уиа     д5г(М2)         , адрес возврата = д5г
***************************************************
* МДНАП – ПОДГОТОВКА МОДИФИКАТОРОВ ПО НОМЕРУ
* УСТРОЙСТВА (НАПР, ЛИНИЯ, УСТР-ВО).
* ВХОД: СМ – УПРАВЛЯЮЩЕЕ СЛОВО (КУС) ЗАКАЗА,
* СОДЕРЖАЩЕЕ ПОЛЯ НАПР. (40-42), ЛИНИИ (37-39),
* УСТР-ВА (33-36).
* ВЫХОД: М1 – НАПР+ЛИНИЯ+УСТР-ВО,
* М4 – НОМЕР УСТР-ВА (ИНВЕРСНЫЙ),
* М15 – НОМЕР УСТР-ВА (ПРЯМОЙ),
* М3 – НАПР+ЛИНИЯ.
* ИСПОЛЬЗУЕТ: М2 (АДРЕС ВОЗВРАТА).
***************************************************
МДНАП   СБР     НАПРМГ          , сбросить биты направления (40-42)
        СДА     64+42           , сдвиг вправо на 42 (выделить 1-6)
МДНАП1  УИ      М1              , М1: НАПР,ЛИНИЯ,УСТР-ВО (биты 1-12)
        И       П37             , выделить номер устройства (биты 1-5)
        УИ      М4              , М4 = номер устройства (1-32?)
        И       Е3П1            , выделить биты 1-3
        НТЖ     Е3П1            , инвертировать
        УИ      М15             , М15 = инверсный номер устройства
        СЧИ     М1              , взять полный код М1
        СДА     64+3            , сдвиг вправо на 3 (убрать устройство)
        УИ      М3              , М3 = НАПР+ЛИНИЯ (биты 4-12)
        ПБ      (М2)            , возврат
*
***************************************************
* Д73 – ПОИСК ЗАКАЗА К ОСВОБОЖДЁННОМУ НАПРАВЛЕНИЮ.
* ЕСЛИ ЗАКАЗ НАЙДЕН – ФОРМИРУЕТ ЗАПРОС К ПРИОРИТЕТНОЙ
* ЛИНИИ НАПРАВЛЕНИЯ.
* ИСПОЛЬЗУЕТ: М16 (НАПРАВЛЕНИЕ), М14 (ЗАКАЗ),
* М3 (ЛИНИЯ), М11 (ВОЗВРАТ), М2 (АДРЕС ВОЗВРАТА).
***************************************************
Д73     сч      ШОЧНМД-3(М16)   , загрузить шкалу очереди к напр.
        по      Д9              , если пусто – нет заказов
        уиа     '3'             , разрешить прерывания
        и       СИСТ            , проверить системные заказы
        пе      дси             , если есть – приоритет
        сч      ШОЧНМД-3(М16)   , иначе все заказы
дси     нед                     , найти старший заказ
        уи      М14             , сохранить номер заказа
        сч      ОЧКУСД-1(М14)   , взять управляющее слово заказа
        зп      ОЖОСВ-3(М16)    , записать в очередь ожидания напр.
        сда     64+39           , выделить номер линии
        и       П7
        уи      М3              , сохранить линию в М3
        пв      ЗАПРОС(М11)     , выдать запрос к линии направления
        уиа     дс+1(М2)        , адрес возврата = дс+1
        пб      УСТШЗ           , установить шкалу задержки (ХЛАМ)
*
Д8      сч      СОД-3(М16)      , загрузить СОД направления
        и       Е24П17          , проверить биты занятости обменом
        пе      Д8А             , если занято – к Д8А
        сч      СОД-3(М16)      , иначе взять поле подвода
        и       П377
        пв      открмд(М10)     , открыть в КМД маску устр. без фикс. прер.
Д8А     сч      E32(М16)        , открыть маску 29(28) разряда в МГРП
Д9      или     ЯМГРП           , добавить к накопленной маске
        зп      ЯМГРП           , сохранить
ДВ      уиа     Д1+5(М2)        , адрес возврата = Д1+5
        пб      УСТШЗ           , гасить 44(43) разр., устан. 40 в ШЗПОМД
***************************************************
* прб – ОБРАБОТКА ЗАДЕРЖКИ ПРЕРЫВАНИЙ ОТ МД
* (ЦИКЛИЧЕСКИЙ ОПРОС ГОТОВНОСТИ).
* ИСПОЛЬЗУЕТ: М16 (НОМЕР НАПРАВЛЕНИЯ).
***************************************************
прб     сч      п7600-3(М16)    , загрузить таймер/флаг задержки
        и       типком-3(М16)   , проверить тип команды обмена
        по      б               , если 0 – обход
        сч      п7600-3(М16)
        слц     E43             , добавить 43 (смещение?)
        по      прб1            , если стало 0 – будильник истёк
        зп      п7600-3(М16)    , сохранить обновлённый таймер
б       цикл    прб(М16)        , следующий номер напр. (3 или 4)
        пб      ВЫЗРЕЗ          , вызов резидента планировщика
* !МАЛ. ПРБР ОТ ДРУГОЙ ЭВМ КОМПЛЕКСА. М16=3(3 НАПР.), 4(4 НАПР.)
* ДАЛЕЕ ТЕКСТ ПО УСЛ. КОМП. ОТЛИЧАЕТСЯ.
*
***************************************************
* ПРЗАХВ – ОБРАБОТКА ПРЕРЫВАНИЙ ЗАХВАТА МД
* (ОТ ДРУГИХ МАШИН КОМПЛЕКСА).
* ИСПОЛЬЗУЕТ: М16 (НАПРАВЛЕНИЕ).
***************************************************
ПРЗАХВ  сч      ГОД             , загрузить номер ЭВМ (ГОД)
        и       Е46П48          , выделить номер машины (46-48)
        или     ЗУС-3(М16)      , добавить запросы устройств
        по      БМВ             , если 0 – выход
        сч      НОМРМД-3(М16)   , загрузить рабочие устройства
        зп      ПРОСВ-3(М16)    , сохранить в просвете
        сч      ОЖОСВ-3(М16)    , проверить ожидание освобождения
        пе      БМВ             , если есть – выход
        сч      ШЗПОМД          , проверить флаг задержки МД
        пе      прос4           , если не 0 – особая обработка
        или     Е48-1(М16)      , установить бит направления
        зп      ШЗПОМД          , обновить шкалу задержки
        уиа     ПРО(М15)        , адрес процедуры ПРО
        пб      прмд2           , переход к прмд2
прос4   или     Е48-1(М16)      , установить бит направления
        пб      пд              , переход к пд
ПРО     сч      Е48-1(М16)      , взять бит направления
        пб      ПРОХ1           , переход к ПРОХ1
ПРОХ    сч      НОМРМД-3(М16)   , загрузить рабочие устройства
        зп      ПРОСВ-3(М16)    , сохранить
        сч      E29(М16)        , код 29(28) для данного напр.
ПРОХ1   уиа     '3'             , разрешить прерывания
        зп      РАЗЛ            , сохранить флаг "различный"
        уиа     -3(М3)          , цикл по 4 линиям направления
ПРОС1   сч      ПРОСВ-3(М16)    , загрузить просвет
        по      ПРОС11          , если 0 – к ПРОС11
        и       Е24П17+2(М3)    , проверить биты устройств линии
        пе      ПРОС11          , если есть – к ПРОС11
        цикл    ПРОС1(М3)       , следующая линия
ПРОС11  сч      ЗУС-3(М16)      , проверить запросы устройств
        или     ОСУ-3(М16)      , добавить ожидания освобождения
        и       Е24П17+2(М3)    , для данной линии
        пе      прос2           , если есть – особая обработка
        сч      ГОД             , проверить номер ЭВМ
        и       Е46П48
        пе      прос2           , если не 0 – обработка
        цикл    ПРОС1(М3)       , продолжить цикл
        сч                      , очистить
        зп      ПРОСВ-3(М16)    , сбросить просвет
ПС1     сч      РАЗЛ            , взять флаг "различный"
        пб      Д3А1            , переход к завершению
прос2   слиа    3(М3)           , коррекция номера линии
        счи     М16             , взять номер направления
        и       E3              , выделить младший бит (чётность?)
        уи      М10             , сохранить
        сли     М3(М10)         , скорректировать М3
        сч      E5(М16)         , взять бит 5 направления
        или     рад             , добавить к рабочей адреса
        зп      рад             , сохранить
        сч      ЗАНКМД-3(М16)   , проверить занятость канала
        и       E48
        пе      пс              , если занято – к пс
        счи     М3              , проверить открыта ли линия
        сда     64-3
        нтж     ЗАНКМД-3(М16)
        пе      ПС1             , если не открыта – к ПС1
        пв      зсс1(М10)       , вызов зсс1 (сброс счётчиков)
        уиа     '2003'          , блокировка прерываний
        сч      РАЗЛ            , флаг различный
        нтж     ШЗПОМД          , сбросить бит в шкале задержки
        или     E40             , установить бит 40
        зп      ШЗПОМД
        пб      зс100           , переход к зс100 (ХЛАМ)
***************************************************
* УЧАСТОК ОБРАБОТКИ ОСВОБОЖДЕНИЯ УСТРОЙСТВ И
* ФОРМИРОВАНИЯ ЗАПРОСОВ К НМД.
* МЕТКИ: зс1 ... д102
***************************************************

* зс1 – ПРОВЕРКА СОВПАДЕНИЯ ОТВЕТА ОТ ДРУГОЙ
* МАШИНЫ КОМПЛЕКСА ПРИ ЗАХВАТЕ МД.
* ИСПОЛЬЗУЕТ: М2 (АДРЕС ВОЗВРАТА), М5 (НОМЕР МАШИНЫ),
* М16 (НАПРАВЛЕНИЕ), РЯД1, РЯД2.
зс1     нтж     РЯД1            , сравнить ответ с эталоном
        по      зс4             , совпало – освобождение
        нтж     РЯД1            , восстановить
        уии     М5(М2)          , М5 = М2 (базовый индекс)
        сли     М5(М2)          , М5 = М5 + М2
        сли     М5(М2)          , М5 = М5 + М2 (утроение)
        сда     64(М5)          , сдвиг на М5 (выделение бита машины)
        уи      М5              , сохранить номер машины
        сч      негтб           , флаг неготовности таблицы
        и       E13(М5)         , проверить бит для этой машины (12р = 1я)
        по      зс11            , если 0 – не сброшена
        сч      П7              , иначе сброс маски
        сд      ну20+5(М2)      , сдвиг по таблице
        нтж     ВСЕЕД           , инвертировать
        и       РЯД2            , очистить биты в РЯД2
        зп      РЯД2
        пб      зс13            , переход к зс13
        пам     0
*
* д11 – ОБРАБОТКА ПРИ НАЛИЧИИ ЗАКАЗА К УСТРОЙСТВУ
* С ПОВЫШЕННЫМ ПРИОРИТЕТОМ (ДИАГНОСТИКА).
* ИСПОЛЬЗУЕТ: М1, М16, М14, М2.
д11     сч      ШОЧМД(М1)       , загрузить шкалу очереди к устройству
        и       ШОЧНМД-3(М16)   , проверить совпадение с напр.
        по      дзс             , если пусто – к дзс
        пв      ОПРЗАК(М2)      , определить номер заказа
        сч                      , очистить
        пб      д1а             , переход к д1а
*
* д102 – ВСПОМОГАТЕЛЬНАЯ ПРОЦЕДУРА ДЛЯ
* ОСВОБОЖДЕНИЯ УСТРОЙСТВА И УСТАНОВКИ ПРИЗНАКА
* ЗАВЕРШЕНИЯ РАБОТЫ С НИМ.
* ИСПОЛЬЗУЕТ: М16, М17, М10.
д102    сч                      , очистить сумматор
        увв     '20'(М16)       , выдать команду в КМД (освоб.устр.)
        уи                      , сброс индекса
        уиа     '2003'          , блокировка прерываний
        сч      Е32П25(М17)     , маска устройства по номеру М17
        или     ПРОСВ-3(М16)    , добавить к просвету
        нтж     Е32П25(М17)     , сбросить бит (убрать из просвета)
        зп      ПРОСВ-3(М16)    , обновить просвет
        пб      (М10)           , возврат по М10
*
***
*
*
***************************************************
* прмд – ВХОД ПО ПРЕРЫВАНИЮ ОТ 29(28) РАЗРЯДА ГРП
* (ПРЕРЫВАНИЕ ОТ МД). ГАСИТ ПРЕРЫВАНИЕ И АНАЛИЗИРУЕТ
* ПРИЧИНУ.
* ИСПОЛЬЗУЕТ: М16 (НОМЕР НАПРАВЛЕНИЯ).
***************************************************
прмд    сч      E32(М16)        , взять маску прерывания для напр.
        пв      ТВ67А(М15)      , гасить 29(28) разряд МГРП (ТВ67А)
*
        АПУ     (&К71).ДА5      , если К71 – дополнительный тест
        АПБ     .НЕТ4
.ДА5    АНОП
        сч      aпрмд7          , загрузить адрес процедуры
        пб      дтпре           , переход к тесту прерываний (МОТТ)
aпрмд7  конд    A(прмд7)        , адрес прмд7
.НЕТ4   АНОП
прмд7   сч      ШКПРЕ           , загрузить шкалу программных прерываний
        или     E32(М16)        , установить бит направления
        нтж     E32(М16)        , сбросить его (??)
        зп      ШКПРЕ
        сч      ОЖОСВ-3(М16)    , проверить очередь ожидания
        по      прмд1           , если 0 – прерывание не по запросу
        сч      E4              , иначе: гашение регистра состояния
        увв     '20'(М16)       , выдать команду в КМД
        уи
        сч      ШЗПОМД          , шкала задержки обмена
        или     64(М16)         , установить бит 64? (маска)
        пб      пд              , переход к обработке
пбу     сч      E18             , установить бит 18
        пб      прк             , переход к формированию флага
прб1    сч      типком-3(М16)   , тип команды
        и       Е24П17          , проверить биты подвода
        пе      пбу             , если есть – к пбу
        сч      E17             , иначе установить бит 17
прк     или     п7600-3(М16)    , добавить к флагу
        и       Е18П1           , выделить младшие 18 бит
        зп      п7600-3(М16)    , обновить флаг
        слиа    4(М16)          , следующий индекс (М16+4)
        сч      ВСЕЕД           , все единицы
        нтж     E32(М16)        , сбросить бит 32
        уи                      , сброс индекса
        рег     '37'            , гашение 29(28) разряда ГРП и маски
        сч      E32(М16)        , маска прерывания
        пв      ТВ67А(М15)      , вызов гашения маски ГРП

прмд1   сч      ШЗПОМД          , загрузить шкалу задержки
        и       E47(М16)        , проверить бит 47 для напр.
        пе      БМВ             , если установлен – выход (уже занято)
        сч      ШЗПОМД
        или     E47(М16)        , установить признак: обработать прер.
        зп      ШЗПОМД
        нтж     E47(М16)        , сбросить его (??)
        пе      БМВ             , если стало 0 – выход (п.о. МД занята)
        уиа     прпо(М15)       , адрес прпо -> ИПЗМД+3 (вход после перекл.)
        пб      прмд2           , переход к прмд2
пд      зп      ШЗПОМД          , сохранить шкалу задержки
        нтж     64(М16)         , сбросить бит 64?
        пе      БМВ             , если не 0 – выход
        уиа     ВХД(М15)        , адрес ВХД для повторного входа
прмд2   счи     М15             , сохранить адрес
        зп      ИПЗМД+3         , в 3-е слово ИПЗ МД
        счи     М16             , сохранить номер напр.
        зп      ИПЗМД+8         , в 8-е слово ИПЗ МД
        сч      Е43Е42          , маска 43-42 (приоритет?)
        зп      ИПЗМД+1         , в 1-е слово ИПЗ МД (РК)
        уиа     БПУ(М15)        , адрес возврата = БПУ (полное упрятывание)
        сч      E44             , код 44 (активация дисков)
        пб      ВШГ             , переход к установке шкалы готовности
*
Д4А     сч      ШЗПОМД          , загрузить шкалу задержки
        и       Е44Е43          , проверить биты 44 и 43
        по      ДОС             , если 0 – не было прер. по подв/обмену
        нед     Е15П2           , найти старший бит (номер напр.)
        уи      М16             , М16 = номер направления
прпо    сч      СОД-3(М16)      , загрузить СОД направления
        сда     64+16           , выделить поле "подвод" (биты 17-24)
        и       П377
        пе      прпо1           , если не 0 – было прерывание по оконч. обмена
        мода                    , сброс модификации
        пв      счрс(М10)       , чтение регистра состояния
        сч      СОД-3(М16)      , СОД направления
        сда     64+8            , выделить единицы для модулей
        и       рс              , проверить регистр состояния
        и       П377
        пе      прпо1           , если есть – к прпо1
        сч      СОД-3(М16)      , нет КП, выделение устр., участв. в подводе
        и       П377
прпо1   зп      ЯПРМД-3(М16)    , сохранить в шкале прерываний МД
        пб      Д5              , переход к анализу завершения обмена
***************************************************
* Д10 – ЗАПУСК ЦИКЛИЧЕСКОГО ОПРОСА ГОТОВНОСТИ МД
* (ОПРГД) ИЛИ ОЖИДАНИЕ ОСВОБОЖДЕНИЯ НАПРАВЛЕНИЯ.
* ИСПОЛЬЗУЕТ: М16 (НАПРАВЛЕНИЕ), М15 (СЧЁТЧИК),
* М3 (ЛИНИЯ), М10 (КОРРЕКЦИЯ ЛИНИИ).
***************************************************
Д10	уиа	3(М16)          , начальный номер напр. = 3 (первый канал МД)
	уиа	-1(М15)         , счётчик цикла = -1 (два напр.: 3 и 4)
	сч	ЗАВ             , проверить флаг завершения обмена
	пе	НОВ             , если не 0 – переход к НОВ (аварийная смена)
	сч	ШЗПОМД          , загрузить шкалу задержки обмена МД
	и	E24             , проверить бит 24 (работа по ОПРГД?)
	по	ДКП             , если 0 – нет опроса, к ДКП
ДКК	сч	НОМРМД-3(М16)   , загрузить рабочие устройства напр.
	зп	ДАЙГОТ-3(М16)   , сохранить в шкале готовности
	пе	ДИП             , если не 0 – есть готовые, к диспетчеру
	уиа	4(М16)          , переключить на направление 4
	цикл	ДКК(М15)        , цикл по обоим напр. (3,4)
	пб	ДИП             , переход к ДИП (диспетчер прерываний)
*
ДГ2	сч	ШЗПОМД          , загрузить шкалу задержки
	или	E40             , установить бит 40 (признак запроса)
	зп	ШЗПОМД          , обновить
	уиа	'3'             , разрешить прерывания
	слиа	3(М3)           , коррекция номера линии
	счи	М16             , номер напр.
	и	E3              , выделить младший бит (чётность?)
	уи	М10             , сохранить в М10
	сли	М3(М10)         , скорректировать линию
	сч	ЗАНКМД-3(М16)   , проверить занятость канала
	и	E48
	по	дг4             , если канал открыт – к дг4
	сч	ОЖОСВ-3(М16)    , иначе проверить ожидание освобождения
	пе	ЗАН             , если есть – к ЗАН (ожидание)
	счи	М3              , взять номер линии
	сда	64-39           , сдвинуть для поля запроса
	или	П377            , добавить маску всех устройств (0-7)
	пб	дс              , переход к формированию запроса (дс)
дг4	счи	М3              , взять номер линии
	сда	64-3            , сформировать бит открытия линии
	нтж	ЗАНКМД-3(М16)   , сравнить с текущей занятостью
	АПУ	(&К71).ДА6       , если К71 – особая проверка
	пе	зан             , штатно: если не совпало – ожидание
	АПБ	.НЕТ5
.ДА6	АНОП
	пе	опргд2          , К71: проверка удалённого МД
.НЕТ5	АНОП
	уиа	'2003'          , блокировка прерываний
	сч	ШЗПОМД
	и	О40             , сбросить бит 40 (очистить запрос)
	или	E47(М16)        , установить бит прерывания для напр.
	зп	ШЗПОМД
	пб	ОПРГД           , переход к опросу готовности дисков
*
дипд	сч	ШЗПОМД          , диспетчер при пустой шкале задержки
	АПУ	(&К71).ДА6А
	или	Е24             , установить бит 24
	нтж	Е24             , сбросить бит 24
	зп	ШЗПОМД
дко	уиа	-3(М3)          , счётчик линий в одном напр. (4 линии)
	сч	СОД-3(М16)      , загрузить состояние обмена
	и	Е8П1            , проверить биты подвода
	пе	зан             , если есть подвод – ожидание
дг	сч	ДАЙГОТ-3(М16)   , загрузить шкалу готовности
	и	Е32П25+3(М3)    , проверить устройства конкретной линии
	пе	дг2             , если есть готовые – к ДГ2
зан	уиа	1027            , блокировка прерываний
	сч	ШЗПОМД
	и	О40             , сбросить 40-й разряд
	зп	ШЗПОМД
.ДА6А	АНОП
	пе	Д33             , если ШЗПОМД не 0 – вернуться к Д33
	АПУ	(&К71).ДА6Б
	пб	дк              , штатно – переход к ДК (планировщик)
дкп	сч	ДАЙГОТ+1(М15)   , ожидание освобождения: проверка второго напр.
	пе	дко             , если есть готовые – к дко
	сч	ПРОСВ-3(М16)    , загрузить просвет (ожидающие устройства)
	по	ппр             , если 0 – к ппр
пп	сч	НЗ-3(М16)       , проверить наличие заказов на напр.
	по	ппи             , если нет – к ппи
	сч	СОД-3(М16)      , состояние обмена
	и	Е24П17          , проверка занятости обменом
	или	ОЖОСВ-3(М16)    , или ожидания освобождения
	пе	ппи             , если что-то активно – к ппи
	сч	ШЗПОМД
	или	Е42-3(М16)      , установить бит задержки для напр.
	зп	ШЗПОМД
	пб	про             , переход к освобождению ресурсов
ппр	сч	ОСУ-3(М16)      , проверить ожидания освобождения устр.
	пе	пп              , если есть – к пп
ппи	уиа	4(М16)          , переключить на напр. 4
	цикл	дкп(М15)        , цикл по напр. (3,4)
.ДА6Б	АНОП
дк	сч	ИВ25            , загрузить конфигурацию прерывания
	зп	ИПЗМД+5        , сохранить в ИПЗ МД (поле М27)
	сч	блоз            , проверить блокировку ошибок
	пе	ВИСП16          , если есть – к восстановлению
	сч	E44             , код 44 (диски)
	пв	ИЗШГ(М15)       , исключить из системной шкалы готовности
	сч	ШКОБМ           , взять шкалу обмена
	пв	ВШГ(М15)        , установить в системную шкалу
	сч	                , очистить
	зп	ШКОБМ           , сбросить шкалу обмена
	пб	БВЗ             , переход к выбору задачи (БВЗ)
*
ОСВКМД	уиа	'2003'          , блокировка прерываний
	или	ОСУ-3(М16)      , установить бит ожидания освоб. устр.
	зп	ОСУ-3(М16)
	сч	НЗ-3(М16)       , проверить наличие заказов
	пе	ОСВУ            , если есть – к ОСВУ (ХЛАМ)
	АПУ	(&К71).ДА7
	сч	Е48-3(М16)      , штатно – бит 48 для напр.
	АПБ	.НЕТ6
.ДА7	АНОП
