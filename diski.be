        и       НАПРМГ          , ВЫДЕЛИТЬ ПОЛЕ НАПРАВЛЕНИЯ
        пе      eq              , ЕСЛИ НЕ СОВПАДАЕТ – К eq
        сч      ГУС             , ЗАХВАТ СИСТЕМНОЙ ЛЕНТЫ: СОХРАНИТЬ ГУС
        зп      зандк7          , В СПЕЦИАЛЬНУЮ ЯЧЕЙКУ (ДЛЯ К-71)
        счи     М15             , СОХРАНИТЬ М15 (АДРЕС ВОЗВРАТА?)
        зп      см1             , В ЯЧЕЙКУ см1
        пб      eq              , ПЕРЕЙТИ К ОСНОВНОЙ ОБРАБОТКЕ
.НЕТ10  АНОП
eq1     уиа     ENQ(М16)        , УСТРОЙСТВО ЗАНЯТО: ПОДГОТОВИТЬ
*                               , АДРЕС ВОЗВРАТА = ENQ
        мод     НЗАД            , ВЗЯТЬ НОМЕР ТЕКУЩЕЙ ЗАДАЧИ
