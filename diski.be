.НЕТ7	АНОП
освкм1	сч	НЗ-3(М16)       , проверить заказы
	уиа	'2003'
	пе	ОСВМД           , если есть – к ОСВМД
	сч	ШЗМД-3(М16)     , шкала захватов МД
	или	ЕNQМДС-3(М16)   , добавить счётчики ENQ
	АПУ	(&К71).ДА9
	и	мзахв-3(М16)    , штатно – проверка маски захвата
	пе	ОСВ1            , если не 0 – КМД осв. нельзя
	АПБ	.НЕТ8
.ДА9	АНОП
	пе	освл            , К71 – специальная обработка
.НЕТ8	АНОП
ОСВМД	сч	СОД-3(М16)      , состояние обмена
	пе	ОСВ1            , если обмен не завершён – нельзя
	сч	ЗАНКМД-3(М16)   , загрузить занятость канала
	зп	ПРСКМД-3(М16)   , сохранить для восстановления
	сч	НЗ-3(М16)       , проверить заказы
	по	ос1             , если нет – к ос1 (ХЛАМ)
	сч	РАЗЛ(М16)       , флаг "различный"
	пе	освру           , если установлен – освоб. с возвратом
	уиа	осе(М11)        , адрес возврата для освобождения
***************************************************
* ос4 – ОСВОБОЖДЕНИЕ НАПРАВЛЕНИЯ МД
* (ПРОДОЛЖЕНИЕ ПРОЦЕДУРЫ ОСВКМД).
* ИСПОЛЬЗУЕТ: М16 (НАПР.), М3 (ЛИНИЯ), М17,
* М11 (АДРЕС ВОЗВРАТА), М5, М15, М14.
***************************************************
ос4     счи     М3              , взять номер линии
        и       П3              , выделить младшие 3 бита (0-7)
        уи      М17             , М17 = номер линии
        пб      осж             , переход к осж (обработка освобождения)
ос4а		сч      рс              , загрузить регистр состояния
        уиа     '3'             , разрешить прерывания
        по      дисвх3          , если рс = 0 – переход к дисвх3
        уии     М14(М11)        , сохранить адрес возврата (М11) в М14
        нед     Е15П1           , найти старший бит в рс (номер устройства)
        уи      М15             , М15 = номер устройства
        сда     64+2            , сдвиг вправо для выделения кода ошибки
        и       E1              , проверить младший бит
        уи      М11             , сохранить в М11
        слиа    16(М11)         , добавить смещение 16 (тип ошибки?)
        счи     М16             , взять номер направления
        и       E3              , проверить чётность (бит 1)
        сда     64-3            , сдвинуть для формирования индекса
        уи      М5              , М5 = индекс
        мода    (М5)            , модификация по индексу
        сч      КРЗБТР+1(М15)   , проверить разрешён ли тест для устр.
        пе      освм1           , если да – пропустить
        пв      зсс(М5)         , вызов зсс (сброс счётчиков)
        счи     М15             , взять номер устройства
        и       П3              , выделить младшие 3 бита
        уи      М5
        сч      П7              , маска 7
        сд      ну20+5(М5)      , сдвиг для формирования маски
        зп      ИНФСД           , сохранить в информационном слове диска
        сч      ГОД             , номер ЭВМ (ГОД)
        и       П7              , выделить номер ЭВМ
        сд      ну20+5(М5)      , сдвинуть аналогично
        нтж     РЯД2            , сбросить биты в РЯД2
        зп      РЯД2
        и       ИНФСД           , проверить пересечение с ИНФСД
        пе      нета            , если есть – не та машина
        слиа    -2(М11)         , иначе коррекция смещения
        мода                    , сброс модификации
        пв      чр2(М5)         , вызов чр2 (чтение регистра?)
нета    уиа     '2003'          , блокировка прерываний
        сч      ОСУ-3(М16)      , сбросить бит в ОСУ для устр. М15
        нтж     E48(М15)
        зп      ОСУ-3(М16)
освм1   уии     М11(М14)        , восстановить адрес возврата из М14
        пб      освм            , переход к освм (ХЛАМ)
***************************************************
* дисвх3 – ВОССТАНОВЛЕНИЕ СИСТЕМНЫХ ШКАЛ ПОСЛЕ
* ОСВОБОЖДЕНИЯ УСТРОЙСТВ И ВЫДАЧА СИГНАЛА
* ПРЕРЫВАНИЯ ВСЕМ ЭВМ КОМПЛЕКСА.
* ИСПОЛЬЗУЕТ: М15, М16 (НАПР.), М11 (ВОЗВРАТ).
***************************************************
дисвх3  сч      ШКЗАКС          , загрузить шкалу заказов системных
        пв      ВШГ(М15)        , установить бит в системной шкале готовности
        сч      ШКЗАКЗ          , загрузить шкалу заказов задач
        пв      ВШГП(М15)       , установить бит в польз. шкале готовности
        сч                      , очистить сумматор
        зп      ШКЗАКС          , обнулить шкалу заказов системных
        зп      ШКЗАКЗ          , обнулить шкалу заказов пользовательских
        уиа     '10200'(М15)    , код "прерывание всем ЭВМ комплекса"
        счи     М15             , (о том, что освободили устройства)
        увв     '20'(М16)       , выдать стр. 661-663 (команда в КМД)
        уи                      , сброс индекса
        сч      E5(М16)         , взять бит 5 направления
        уии     М15(М11)        , восстановить адрес возврата
        пб      УСТПРП          , переход к установке маски ПРП
*
ОСВ1    сч                      , очистить сумматор
        пб      (М6)            , возврат по адресу в М6
*
***************************************************
* освру – ОСВОБОЖДЕНИЕ С ВОЗВРАТОМ РЕСУРСА
* (ПРИ УСТАНОВЛЕННОМ ФЛАГЕ "РАЗЛИЧНЫЙ").
* ИСПОЛЬЗУЕТ: М5, М16, М11.
***************************************************
освру   уиа     1(М5)           , М5 = 1 (признак освоб. с возвратом)
        пб      выза            , переход к выза (процедура выдачи заказа)
***** БЛОК ВЫДАЧИ ЗАКАЗА В КМД *****
*
* ПОДОБМ – ПОДГОТОВКА И ВЫДАЧА ЗАКАЗА В КАНАЛ МД.
* ВХОД:  М16 – НОМЕР НАПРАВЛЕНИЯ (3 ИЛИ 4),
*        М14 – НОМЕР ЗАКАЗА В ОЧЕРЕДЯХ (ОЧКУСД/ОЧЛИСД),
*        М1  – КОД УСТРОЙСТВА (НАПР+ЛИНИЯ+УСТР-ВО),
*        М15 – ИНВЕРСНЫЙ НОМЕР УСТРОЙСТВА,
*        М4  – НОМЕР УСТРОЙСТВА (ПРЯМОЙ, 0-7),
*        М3  – НОМЕР ЛИНИИ (0-7),
*        М11 – АДРЕС ВОЗВРАТА.
* ВЫХОД: ПРИ УСПЕХЕ – АППАРАТНЫЙ СТАРТ ОБМЕНА ЧЕРЕЗ КМД,
*        ИНАЧЕ ВОЗВРАТ ПО М11 (УСТРОЙСТВО ЗАНЯТО).
* ИСПОЛЬЗУЕТ: М2, М5, М7, М10, М12, М13.
ПОДОБМ  сч      СОД-3(М16)      , загрузить состояние обмена напр.
        уиа     '3'             , разрешить прерывания
        и       П377            , проверить поле "подвод" (биты 1-8)
        пе      (М11)           , если не 0 – уже есть подвод, возврат
        сч      БУДАВ-3(М16)    , загрузить таймер/флаг задержки
        и       E8(М15)         , проверить бит устройства (М15)
        пе      (М11)           , устройство занято – возврат
        пв      ОПРЗАК(М2)      , поиск готового заказа (->М14)
A74202  сч      СИСТ            , загрузить шкалу системных заказов
        или     Е48-1(М14)      , установить бит текущего заказа
        зп      СИСТ            , заказ помечен как системный
        сч      МД29М-3(М16)    , проверить: 29-МБ диск?
        и       E32(М4)         , бит устройства (М4 – номер МД)
        уиа     (М5)            , М5 = 0 (обычный диск)
        по      подв            , если 0 – не 29 МБ, к подв
        уиа     1(М5)           , М5 = 1 (29 МБ диск)
подв    сч      ОЧКУСД-1(М14)  , загрузить управляющее слово заказа
        и       E7              , проверить бит 7 (тестовый режим)
        по      подвод          , если 0 – не тестовый, к подвод
* ОБРАБОТКА ТЕСТОВОГО РЕЖИМА
        сч      ОЧКУСД-1(М14)  , загрузить КУС заказа
        сда     64+42           , выделить номер задачи (старшие 6 бит)
        уи      М10             , М10 = номер задачи
        мод     НЗАД(М10)       , загрузить слово из ИПЗ задачи
        сч      E48             , 48-й разряд (признак задачи)
        сда     64-21           , сдвинуть в поле тестовых битов
        рзб     КРЗБТР          , разобрать по маске КРЗБТР
        зп      КОМТР-3(М16)    , сохранить в команде теста
        и       П7              , выделить младшие 3 бита (код команды)
        зп      РЯД             , сохранить в РЯД
        нтж     КОМТР-3(М16)    , сбросить эти биты в КОМТР
        и       Е40П1           , очистить всё кроме младших 40 бит?
        или     ОЧКУСД-1(М14)   , объединить с КУС заказа
        зп      ОЧКУСД-1(М14)   , обновить КУС заказа
        сч      РЯД             , взять код команды
        вч      П3              , сравнить с 3
        пе      под7            , если не 3 – подвод со сбросом на 0-й цилиндр
        сч      РЯД             , иначе тип команды обмена -> типком/н
        зп      типком-3(М16)
        пб      по              , переход к формированию команды
подвод  сч      ТЗНМД(М1)      , загрузить таблицу зон МД (М1 – устр.)
