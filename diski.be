	мода	                  , сброс модификации
	пв	ПРЛСЧА(М5)        , вызов ПРЛСЧА
	зп	РЯД               , сохранить прочитанное
	уиа	'3'               , разрешить прерывания
	и	Е39П25            , выделить поле ключа (39-25рр)
	нтж	КЛЮЧ              , сравнить с ключом (70707)
	пе	обр2г             , если не совпадает – ошибка
	сч	РЯД               , проверить способ росписи СС
	и	E40               , бит 40 (старый/новый формат)
	по	обр2е             , если 0 – старый формат
	сч	РЯД
	сда	64+12             , сдвинуть для получения номера пакета
	зп	РЯД               , сохранить
обр2е	сч	КУС2-1(М16)       , проверить, был ли опрос (бит 5)
	и	E5
	по	обр2в             , если нет – к обр2в
