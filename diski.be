	пв	анкобм(М10)
	сч	П6                , вернуть код 6 (успех?)
	пб	обр               , переход к завершению
обр1а	сч	E38               , код 38 (ошибка чтения заголовка)
	пб	дисвх1            , завершить с ошибкой
обр2	сч	ЛИС2-1(М16)       , загрузить адрес буфера обмена
