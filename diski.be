* ВЫБРЗК – ВЫБРОС ЗАКАЗА ИЗ ОЧЕРЕДИ, СБРОС ПРИЗНАКОВ
* ЗАНЯТОСТИ УСТРОЙСТВА, ОЧИСТКА ТИПА КОМАНДЫ,
* ПРОДВИЖЕНИЕ ОЧЕРЕДИ ЗАКАЗОВ И РАЗБЛОКИРОВКА
* ОЖИДАЮЩИХ ЗАДАЧ.
* ВХОД:  М16 – НАПРАВЛЕНИЕ, М4 – УСТРОЙСТВО, М1 – УСТР.,
*        М14 – НОМЕР ЗАКАЗА, М12 – НОМЕР ЗАДАЧИ,
*        М11 – АДРЕС ВОЗВРАТА, М10 – БАЗА ДЛЯ ВЫЗОВОВ.
***************************************************
ВЫБРЗК  сч      ВСЕЕД           , загрузить все единицы
        нтж     E32(М4)         , сбросить бит устройства М4 (маска
*                               , освобождения устройства)
        и       ЗАНМД-3(М16)    , применить к занятости устройств
        зп      ЗАНМД-3(М16)    , сохранить: устройство освобождено
        сч                      , очистить сумматор
        зп      НОМЛД(М16)      , обнулить номер логического диска
        зп      КУСКИ(М16)      , обнулить количество кусков
        зп      типком-3(М16)   , обнулить тип команды обмена
        сч      квтз            , загрузить маску квтз
        и       ТЗНМД(М1)       , очистить поле в таблице зон МД
        зп      ТЗНМД(М1)       , обновить запись устройства
        уиа     -74(М2)         , М2 = -74 (размер очереди заказов?)
        мода                    , сброс модификации
        пв      ДВОЧД(М10)      , вызов ДВОЧД: выброс заказа и
*                               , продвижение очереди
        сч      ШКОМД           , активировать отложенные обмены МД:
        или     ШКМД            , добавить шкалу занятости МД
        зп      ШКМД            , обновить – "разбудить" ожидающих
        сч      ШКОДП           , то же для пользовательских шкал
        или     ШКМДП
        зп      ШКМДП
        сч                      , очистить
        зп      ШКОДП           , обнулить отложенные (польз.)
        зп      ШКОМД           , обнулить отложенные (системные)
        сч      РЯД2            , проверить бит 17 (признак системной
        и       E17             , задачи?)
        уиа     ВШГ(М10)        , адрес возврата = ВШГ (активация
*                               , системной задачи)
        пе      ОБРФ            , если бит установлен – к ОБРФ
        сч      ШЗЗ             , иначе сбросить блокировку в ШЗЗ
        или     Е48-1(М12)      , установить бит задачи
        нтж     Е48-1(М12)      , сбросить его (разрешить приём сл. ЗК)
        зп      ШЗЗ
        пб      СНЗЩД           , переход к снятию защиты и блокировок
СНЯЛИЗ  сч      41(М10)         , загрузить 41-е слово ИПЗ задачи
        и       Е47П1           , очистить старший бит (снять флаг)
        зп      41(М10)         , обновить ИПЗ
        сч      ШМАРС           , проверить, ожидает ли задача
        и       Е48-1(М12)      , ресурс (шмарс)
        по      выбз            , если нет – к выбз
        или     Ш1М             , иначе установить в шкале ожидания
        зп      Ш1М
        сч      Е48-1(М12)      , сбросить бит в ШМАРС (ресурс получен)
        нтж     ШМАРС
        зп      ШМАРС
        сч      НОМАРС+1        , загрузить номер архивной ссылки?
***************************************************
* ВЫБИ – ПОДГОТОВКА К ВОЗВРАТУ ЗАДАЧИ В ШКАЛУ
* ГОТОВНОСТИ ПОСЛЕ ВЫПОЛНЕНИЯ ЗАКАЗА.
* ВХОД: М12 – НОМЕР ЗАДАЧИ,
*       М16 – НОМЕР НАПРАВЛЕНИЯ (СОХРАНЯЕТСЯ В М5),
*       М2  – АДРЕС ТУС/ИПЗ ЗАДАЧИ,
*       М15 – АДРЕС ПРОЦЕДУРЫ АКТИВАЦИИ (ВШГ ИЛИ ВШГП),
*       М10 – КОД ОПЕРАЦИИ (ВШГ ИЛИ ВШГП).
* ВЫХОД: ЗАДАЧА ВОЗВРАЩЕНА В ШГ ИЛИ ШГП,
*        ПРИ НЕОБХОДИМОСТИ ВЫЗЫВАЕТСЯ ЗАПВЕТ.
ВЫБИ    уии     М5(М16)         , сохранить номер напр. (М16) в М5
        или     E30             , добавить бит 30 (код события "обмен
*                               , завершён")
        уиа     ВШГП(М10)       , М10 = адрес ВШГП (польз. готовность)
        пв      ЗАПВЕТ(М16)     , установить событие для задачи
*                               , (ЗАПВЕТ сохранит М16, использует М10?)
        уии     М17(М2)         , сохранить адрес ИПЗ (М2) в М17
        мод     НЗАД(М12)       , адрес ИПЗ задачи -> М2
        уиа     (М2)            , М2 = адрес ИПЗ задачи
        уии     М16(М5)         , восстановить номер напр. из М5 в М16
        сч      РЯД2            , проверить бит 7 (признак тестовой
        и       E7              , задачи?)
        пе      обр8            , если тест – открыть задачу (обр8)
        пио     обр9(М17)       , если М17=0 (задача не ждёт страницу),
*                               , к обр9
        счи     М13             , иначе проверить, ждёт ли задача
        сда     64-23           , конкретную страницу (М13 – номер листа?)
        или     Е36             , добавить признак "ждать страницу"
        зп      РЯД             , сохранить
        нтж     НЗАД(М12)       , сравнить с текущим ожиданием
        сда     64+23           , выделить поле сравнения
        и       РОДОН+3         , проверить маску ожидания
        пе      обр9            , если ждёт другую – к обр9
        сч      НЗАД(М12)       , иначе сбросить признак ожидания
        нтж     РЯД             , страницы (задача дождалась)
        зп      НЗАД(М12)
        пб      обр8            , открыть задачу (обр8)
*
ОБРФ    мод     ТУС-1(М12)      , получить адрес ТУС задачи
        уиа     (М2)            , М2 = адрес ТУС задачи
обр8    уии     М5(М15)         , сохранить адрес процедуры (М15) в М5
        сч      Е48-1(М12)      , маска задачи
        мода    (М10)           , вызов процедуры активации (ВШГ или ВШГП)
        пв      (М15)           , (адрес в М15, аргумент в СМ)
        уии     М15(М5)         , восстановить М15
обр9    сч      ИПЗМД+33        , учесть время работы П.О. МД
        нтж     E48             , сбросить 48-й разряд
        слц     33(М2)          , добавить к 33-му слову ИПЗ задачи
        зп      33(М2)          , сохранить обновлённое время
        сч      E48             , установить 48-й разряд
        зп      ИПЗМД+33        , вернуть в ИПЗ МД
        уиа     '3'             , разрешить прерывания
        пб      (М11)           , возврат по адресу в М11 (вызвавшая пр.)
выбз    счи     М12             , сохранить номер задачи в СМ
        пб      ВЫБИ            , переход к ВЫБИ (завершение обработки)
*
*** ДИАГНОСТИКА ОШИБОК, ОФОРМИТЬ ОКОНЧАНИЕ***
*** В ЗАВИС. ОТ СИТУАЦИИ                  ***
*
*!ДИСКИ-100 СТР.1738/2124
*** ДИАГНОСТИКА ОШИБОК, ОФОРМИТЬ ОКОНЧАНИЕ
*** В ЗАВИС. ОТ СИТУАЦИИ
обрнев  сч      типош-3(М16)    , загрузить тип ошибки направления
        и       е36е35          , проверить биты 36-35 (дефектные дорожки?)
        по      обрвн1          , если 0 – нет дефектных дорожек в зоне
        сч      типком-3(М16)   , проверить тип команды обмена
        нтж     E3              , сравнить с 3 (чтение?)
        по      обрне1          , если чтение – к обрне1
        сч      П377            , иначе сбросить поле дефектов в ТЗНМД
        сда     64-26           , сформировать маску для очистки
        нтж     ВСЕЕД           , инвертировать
        и       ТЗНМД(М1)       , применить к таблице зон устройства
        зп      ТЗНМД(М1)       , обновить – сняты признаки дефектов
        сч                      , очистить сумматор
        зп      НОМЛД(М16)      , сбросить номер логического диска
        сч      МД29М-3(М16)    , проверить 29-МБ диск
        и       E32(М4)         , бит устройства (М4 – номер МД)
        пе      д5г             , если 29 МБ – к д5г (повторная выдача)
        сч      ОЧЛИСД-1(М14)   , иначе сбросить бит 13 в адресной информации
        нтж     E13
        зп      ОЧЛИСД-1(М14)
        пб      д5г             , переход к повторной выдаче заказа
обрне1  сч      П6              , загрузить код 6 (сравнение после записи)
        зп      типком-3(М16)   , установить как тип команды обмена
        пб      д5г             , повторная выдача

***** ИЗМЕНЕНИЕ МАСКИ КМД *****
гашмд   сч      E9              , вход при гашении РМ КМД (бит 9)
открмд  уиа     -10(М2)         , М2 = -10 (счётчик задержки 10 циклов)
        уиа     '3'             , разрешить прерывания
откр1   сбр     ВСЕЕД           , временная выдержка ≈ 50 мксек
        цикл    откр1(М2)       , цикл задержки
        нтж     Е11Е9           , сформировать код открытия (11 и 9 разряды)
        увв     '20'(М16)       , выдать команду в КМД
        уи                      , сброс индекса
        уиа     -10(М2)         , повторная задержка
откр2   сбр     ВСЕЕД           , ещё 50 мксек
        цикл    откр2(М2)
        пб      (М10)           , возврат

*** ЧТЕНИЕ РЕГИСТРА СОСТОЯНИЯ ***
счрс    уиа     -1(М2)          , М2 = -1: опрос 13-22 разрядов РС
        сбр     ВСЕЕД           , сброс (для опроса 1-12 разрядов М2=0)
счрс1   сч      П11+1(М2)       , загрузить команду (П11=11, П31=31)
        увв     '20'(М16)       , выдать в КМД
        уи
        уи      0               , задержка для БЭСМ-6
        уи
        увв     '4000'(М16)     , чтение регистра состояния на СМ
        пино    счрс2(М2)       , если М2≠0 – обработать старшую половину
        сда     64-12           , сдвинуть младшие 12 разрядов влево
        или     рс              , объединить с ранее прочитанным
счрс2   зп      рс              , сохранить регистр состояния
        цикл    счрс1(М2)       , цикл по двум половинам (М2 = 0, -1)
        пб      (М10)           , возврат
*
*** N МАССИВА, ТИП КОМАНДЫ, N ДОРОЖКИ -> КМД ***
*
***************************************************
* об8 – ПОДГОТОВКА И ВЫДАЧА КОМАНДЫ ОБМЕНА В КМД.
* ВХОД:  М16 – НОМЕР НАПРАВЛЕНИЯ (3 ИЛИ 4),
*        М1  – КОД УСТРОЙСТВА (НАПР+ЛИНИЯ+НОМЕР МД),
*        М4  – НОМЕР УСТРОЙСТВА (ПРЯМОЙ, 1-32),
*        М5  – ТИП ДИСКА (0 – ОБЫЧНЫЙ, 1 – 29 МБ),
*        М14 – НОМЕР ЗАКАЗА В ОЧЕРЕДЯХ,
*        М15 – ИНВЕРСНЫЙ НОМЕР УСТРОЙСТВА,
*        М10 – АДРЕС ВОЗВРАТА ИЗ ПОДПРОГРАММ,
*        М7  – АДРЕС ВОЗВРАТА ПОСЛЕ ВЫДАЧИ (уямгрп),
*        ЛИС2-1(М16) – АДРЕС БУФЕРА ОБМЕНА,
*        КУС2-1(М16) – УПРАВЛЯЮЩЕЕ СЛОВО ОБМЕНА,
*        номдор – НОМЕР ДОРОЖКИ,
*        типком-3(М16) – ТИП КОМАНДЫ ОБМЕНА.
* ВЫХОД:  КОМАНДА ВЫДАНА В КМД, УСТАНОВЛЕНЫ ПРИЗНАКИ
*         ЗАНЯТОСТИ УСТРОЙСТВА И ОЖИДАНИЯ ПРЕРЫВАНИЯ.
***************************************************
об8     зп      1               , записать 0 в БРЗ (начало очистки)
        цикл    об8(М10)        , цикл по 5 раз (М10 = -5) – очистка
*                               , буферных регистров записи (БРЗ 1-5)
        сч      СОД-3(М16)      , загрузить состояние обмена направления
        или     E24(М15)        , установить бит 24 (признак занятости
*                               , направления обменом для устройства М15)
        зп      СОД-3(М16)      , обновить СОД
        уиа     уямгрп(М7)      , М7 = адрес уямгрп – точка возврата
*                               , после завершения всей процедуры выдачи
        сч      ТЗНМД(М1)       , проверить таблицу зон устройства (М1)
        уиа     (М5)            , М5 = 0 (сброс, далее уточнится)
        и       E39             , есть ли дефектная дорожка (E39=1)?
        по      мс1             , если нет – к мс1 (обычная обработка)
        сч      ТЗНМД(М1)       , иначе: проверить наличие дорожки замены
        сда     64+26           , выделить разряды 26-28 (номер дор. замены)
        и       П377            , оставить 8 бит
        по      мс1             , если 0 – обмен с хорошей дорожкой
        сч      КУС2-1(М16)     , взять КУС направления
        и       E11             , проверить бит 11 (признак деф. дорожки?)
        сда     64+10           , сдвинуть для установки в поле "мс2"
        пб      мс2             , переход к мс2
мс1     сч      номдор          , загрузить номер дорожки
        и       E1              , выделить младший бит (чётность?)
мс2     зп      РЯД1            , сохранить в РЯД1 (признак дорожки/замены)
        пв      гашмд(М10)      , вызов гашмд – гашение регистра маски КМД
*                               , (сброс предыдущих команд, подготовка)
        сч      E8(М16)         , взять бит 8 для направления (строб прерывания)
        увв     '31'            , имитация прерывания (установка РБУС в КМД)
        сч      МД29М-3(М16)    , проверить, является ли диск 29-мегабайтным
        и       E32(М4)         , бит устройства (М4)
        по      р               , если не 29 МБ – к "р" (обычный)
        уиа     1(М5)           , М5 = 1 (29 МБ диск)
р       сч      ЛИС2-1(М16)     , загрузить адрес буфера обмена (физический)
        рзб     П14037          , разобрать по маске П14037 – выделить
*                               , номер физического листа и абзаца
        зп      РЯД2            , сохранить в РЯД2
        сч      КУС2-1(М16)     , взять КУС направления
        и       ну20            , выделить поле "ну20" (биты, задающие
*                               , дополнительные признаки обмена)
        или     РЯД2            , добавить адресную информацию (лист/абзац)
        пино    зе(М5)          , если 29 МБ (М5≠0) – переход к "зе"
        или     РЯД1            , для обычного диска добавить признак
*                               , дорожки (РЯД1)
зе      увв     (М16)           , выдать команду "Задание массива обмена"
*                               , в КМД (код команды на СМ, номер напр. в М16)
типобр  сч      МД29М-3(М16)    , снова проверить 29-МБ диск
        и       E32(М4)         , бит устройства
        уиа     (М5)            , М5 = 0 (сброс)
        по      тип             , если не 29 МБ – к "тип"
        уиа     1(М5)           , М5 = 1 (29 МБ)
        сч      номдор          , для 29 МБ: проверить младший бит дорожки
        и       E1              , (используется как расширенный адрес)
        сда     64-9            , сдвинуть в поле типа команды (разряд 10)
тип     или     E8(М15)         , добавить маску устройства (М15),
*                               , формируя команду "Тип обмена"
        пв      открмд(М10)     , вызов открмд – открыть маску устройства в КМД
*                               , (чтобы команда была воспринята именно этим устр.)
типоб   уиа     '2003'          , блокировка прерываний на время выдачи
        сч      СОД-3(М16)      , проверить, был ли подвод (позиционирование)
        и       E16(М15)        , бит 16 для данного устройства
        пе      типоб1          , если подвод был – выдать команду подвода
        сч      ОЧКУСД-1(М14)   , иначе проверить бит 7 (тестовый режим)
        и       E7
        по      типоб7          , если не тест – обычная обработка типа команды
        сч      КОМТР-3(М16)    , тестовый режим: загрузить команду теста
        сда     64+42           , выделить идентификатор задачи (43-48рр)
        или     КОМТР-3(М16)    , добавить к команде
        и       П77             , оставить 6 бит (код команды теста)
        пб      типоб2          , переход к выдаче типа обмена
типоб7  сч      ТЗНМД(М1)       , проверить дефектную дорожку в зоне
        и       E39
        пе      типоб8          , если есть – к типоб8
        сч      номдор          , иначе проверить, является ли дорожка
        вч      п7640-1(М5)     , дорожкой замены (константа п7640/п3720)
        по      типоб9          , если да – к типоб9
        сч                      , обычная дорожка – обнулить
        пб      типоб5
типоб8  сч      ТЗНМД(М1)       , дефектная дорожка: проверить признаки
        и       е36е35          , замены дорожки (разряды 36-35)
        нтж     е36е35
        по      типоб5          , если не было обмена с дор. замены – к типоб5
типоб9  сч      E6              , код 6 (дорожка замены)
типоб5  или     типком-3(М16)   , добавить к типу команды обмена
        пб      типоб2
типоб1  сч      ОЧКУСД-1(М14)   , подвод: проверить тестовый режим
        и       E7
        по      типоб6          , если нет – обычный подвод
        сч      КОМТР-3(М16)    , тестовый подвод: проверить бит 1
        и       E1
        по      типоб6          , если 0 – команда сброса на 0-й цилиндр
сб      увв     '20'(М16)       , выдать команду сброса на 0-й цилиндр
        пб      типоб4
типоб6  сч      E2              , код 2 (команда подвода)
типоб2  увв     '20'(М16)       , выдать тип команды обмена в КМД
        уи                      , сброс индекса
        сч      типком-3(М16)   , проверить, является ли команда
        и       П7              , чтением заголовка (код 7)
        нтж     П7
        по      типоба          , если да – пропустить выбор дорожки
        сч      номдор          , иначе: загрузить номер дорожки
        сда     64(М5)          , сдвинуть (для 29 МБ – без сдвига)
        или     E12             , добавить бит 12 (строб выбора дорожки)
        уи
        увв     '20'(М16)       , выдать команду выбора дорожки в КМД
типоба  уи
        увв     0               , сброс СТВ(I) – задержка для завершения
типоб4  сбр                     , сброс (дополнительная задержка)
        уи
        сбр     0               , временная задержка ≈ 12 мксек
        пв      гашгрп(М10)     , вызов гашгрп – гашение ГРП и маски ГРП
*                               , (очистка возможных прерываний после выдачи)
        сч      СОД-3(М16)      , установить признак выданного заказа
        или     E8(М15)         , бит 8 (ожидание прерывания от устройства)
        зп      СОД-3(М16)      , обновить СОД
        сч      ЗАНМД-3(М16)    , отметить устройство как занятое обменом
        или     E32(М4)         , (М4 – номер устройства)
        зп      ЗАНМД-3(М16)
        уиа     '3'             , разрешить прерывания
        сч      БУДАВ-3(М16)    , установить таймер/флаг задержки
        и       Е16П1           , очистить старшие разряды
        или     E8(М15)         , добавить бит устройства (отметка времени)
        зп      БУДАВ-3(М16)    , обновить БУДАВ
        пб      (М7)            , возврат по адресу в М7 (уямгрп)
