СВЯЗЬ7 СТАРТ '40000'    , адрес загрузки модуля
	Б                  , начало блока констант
	Е                  , начало блока данных
	М                  , начало блока кода
* МОДУЛЬ ОРГАНИЗАЦИИ СВЯЗИ БЭСМ-6 И ДКС
* ЧЕРЕЗ УСТР-ВО КАДОПАМ
*
*              ВХОДНАЯ ИНФОРМАЦИЯ
*
* 1. ПРИ СОЕДИНЕНИИ   С  Д К С:
*
* М2     - НОМЕР ТЕРМИНАЛА
* М3     - СЛОВО ДКС
* М4     - РАБ. РЕГИСТР "СВЯЗЬ7" (база модуля)
* М5     - N НАПР. КРК
* М7     - база вызывающего (Э71ТК или БОНБОТ)
* 41(М7) - АДРЕС КОНЦА ВЫДАВАЕМОГО МАССИВА + 1
* 42(М7) - ДЛЯ ПЕРВОГО ВХОДА <42>, СЛОВО Н-МАШИНЫ
* М10    - АДР. ИНФ. ПОЛЯ ТЕРМИНАЛА
* М13    - адрес начала буфера S‑терминала
* М14    - РАБОЧИЙ ПРИ РАБОТЕ С АС ДКС
* М16    - АДРЕС БУФЕРА S‑ТЕРМИНАЛА
* М17    - РАБОЧИЙ
******
*
*** БЛОК ОПР. ТИПА ОБОРУД., ПОДКЛ. ЧЕРЕЗ ДКС
*
*** !ПРИ ВЫЗ. Э50 '133' НЕ ЗАГР.
* ЗАГР. ПРИ УСТ. НАПР. КРК=0
*
	употр	СВЯЗЬ7(М4)  , рабочий регистр модуля – М4
	уиа	'2003'      , блокировка внешних прерываний
	сч	ШКОРАБ       , загрузить шкалу работ (МОТТ)
	и	ЕЗВ          , проверить бит "будильник"
	пе	навых        , если есть – перейти к обработке
	сч	шзпри7       , шкала запрета приёма ДКС
	и	ШКЭ71        , выделить терминалы, занятые под Э71
	нтж	ШКЭ71        , сбросить их
	и	шкут терм черз ДКС , оставить только терминалы ДКС
	зп	рприем       , сохранить шкалу готовых к приёму
обмдкс	уиа	'2003'      , блокировка прерываний
	по	навых        , если рприем=0 → выход
	нед	Е15П1        , найти старший бит в шкале
	уи	М16          , М16 := номер терминала
	мода	ttvt7        , вызвать ttvt7 – активировать
	пв	(М17)        , будильник и пометить в ШКОРАБ
обдкс1	сч	рприем       , сбросить обработанный бит
	нтж	E48(М16)
	зп	рприем
	уиа	'3'          , разрешить прерывания
	пб	обмдкс       , продолжить цикл
*
ttvt7	сч	E41          , активация будильника приёма
	или	ВППС(М16)    , установить бит E41 в ВППС
	зп	ВППС(М16)
	сч	ЕЗВ          , установить бит "будильник" в
	или	ШКОРАБ       , шкале работ
	зп	ШКОРАБ
	сч	E48(М16)     , отметить терминал в шкале
	или	ШБУДИЛ       , будильников
	зп	ШБУДИЛ
	пб	(М17)        , возврат
*
навых	уиа	'2003'      , блокировка прерываний
	сч	шкраб7       , проверить запросы на загрузку
	по	отксв7 завершить работу с нерезидентом
	нед	Е15П1        , найти старший запрос
	уи	М17          , М17 := номер запроса
	зп	sслово       , сохранить шкалу запросов
	сч	E48(М17) Шкала? , сбросить бит запроса
	нтж	шкраб7
	зп	шкраб7
	уиа	'3'          , разрешить прерывания
*
*** ПЕРЕКЛЮЧАТЕЛЬ
*
тут	мода	тут          , диспетчер по номеру запроса
	пб	(М17) !НА ttvt7 , если 1-й бит → ttvt7
*
	мода                     , если 2-й → трмдкс
	пб	трмдкс  !БЕЗ ВЫЗ. АВТ. "ЭКО"
*
	мода	,                , если 3-й → обдкс4
	пб	обдкс4
*
	уиа	'2003'       , если 4-й → выднаh
	пб	выднаh !НА ВЫХОД
*
*** ПРОВЕРКА ЦЕЛОСТНОСТИ ПОЛУЧЕННОГО ПАКЕТА
*** ВЕРОЯТНО ИСКЛЮЧЕННЫЙ ВАРИАНТ
*
зпшксм	мода	кодтип ВХ. ЧЕРЕЗ НБОБ? , точка входа для
	сч	(М5)         , диагностики: записать СМ
	уи	М16          , в массив рсвясм,
	сч	рсвсм1       , установить бит в рсвсм1
	или	E48(М16)
	зп	рсвсм1
	сч	СМ
	зп	рсвясм(М16)
	пб	авсис        , переход к общей обработке
*****
обдкс4	уиа	'2003'      , блокировка прерываний
	сч	обмен7       , проверить шкалу медленного обмена
	по	СВЯЗЬ7 Не было чтения , если пусто → начало
	нед	Е15П1        , найти старший бит
	уи	М5           , М5 := номер направления
	сч	обмен7        , сбросить бит
	нтж	E48(М5)
	зп	обмен7
*
авсис	счи	М5           , проверка всех направлений
	нтж	всеед7 !ВСЕЕД , если М5 = 48 (все обработаны)
	пе	авсист       , не все → к авсист
	счи	              , иначе обнулить шкалы ошибок
	зп	шкошиб
	зп	шкошиб+1
авсист	уиа	'2003'      , блокировка прерываний
	сч	режим7(М5)   , проверить абонентов направления
	по	обдкс8       , если нет → к обдкс8
	нед	              , найти старшего абонента
	уи	М2           , М2 := номер абонента
	мод	НЗАД(М2)     , адрес ИПЗ задачи (НЗАД – N задачи)
	уиа	0(М15)
	сч	5(М15)       , загрузить 5-е слово ИПЗ (М27)
	или	E23          , добавить бит E23
	нтж	E23          , сбросить его (зачем?)
	зп	5(М15)
	уиа	29(М17)      , код причины 29 (авария ДКС)
	пв	АВОСТА(М16)  , аварийно завершить задачу
	сч	режим7(М5)   , сбросить бит абонента в режим7
	нтж	E48-1(М2)
	зп	режим7(М5)
	сч	шзагс7+1     , сбросить бит в задержке ответа
	нтж	E48-1(М2)
	зп	шзагс7+1
	уиа	'3'          , разрешить прерывания
	пб	авсист       , продолжить цикл
********
*
*
***************************************************
* отксв7 – ОТКАЗ ОТ МОДУЛЯ СВЯЗЬ7.
* ВЫЗЫВАЕТСЯ ИЗ "навых", КОГДА ШКАЛА ШКРАБ7 ПУСТА
* (НЕТ ЗАПРОСОВ НА ПОВТОРНУЮ ЗАГРУЗКУ).
* УСТАНАВЛИВАЕТ БИТ E24 В ШКСВН – МОДУЛЬ СВОБОДЕН.
* СНИМАЕТ БИТ ГЛОБАЛЬНОЙ АКТИВНОСТИ МОДУЛЯ
* В ШКАЛЕ шзагс7 (ПЕРВОЕ СЛОВО, НАПРАВЛЕНИЕ 0).
* ИНДЕКСНЫЙ РЕГИСТР НЕ ИСПОЛЬЗУЕТСЯ, Т.К. ОПЕРАЦИЯ
* ПРОИЗВОДИТСЯ НАД ОБЩИМ ПРИЗНАКОМ, НЕ ЗАВИСЯЩИМ
* ОТ НОМЕРА КАНАЛА.
* ЗАТЕМ ПЕРЕДАЁТ УПРАВЛЕНИЕ НА ВИСП16 ДЛЯ
* ПЛАНИРОВЩИКА.
***************************************************
отксв7  уиа     '2003'       , ЗАПРЕТ ВНЕШНИХ ПРЕРЫВАНИЙ
        сч      ШКСВН        , ШКАЛА ЗАНЯТОСТИ НЕРЕЗИДЕНТОВ
        или     E24           , ДОБАВИТЬ БИТ E24 (СВЯЗЬ7)
        зп      ШКСВН        , ОТМЕТИТЬ МОДУЛЬ СВОБОДНЫМ
        сч      E24           , МАСКА БИТА E24
        и       шзагс7        , ПРОВЕРИТЬ ПЕРВОЕ СЛОВО ШКАЛЫ
* ОТЛОЖЕННЫХ ЗАПРОСОВ (ГЛОБАЛЬНЫЙ ПРИЗНАК
* АКТИВНОСТИ МОДУЛЯ)
        нтж     шзагс7        , СБРОСИТЬ БИТ (СНЯТЬ ЗАПРОС)
        зп      шзагс7
        пб      ВИСП16        , ПЕРЕХОД К ПЛАНИРОВЩИКУ (ДИСП70)
*
***
*
обдкс8	уиа	'2003'      , блокировка прерываний
	сч	новтер(М5)   , загрузить шкалу новых терминалов
*                            для направления М5
	по	обдкс4       , если новых нет → к обдкс4
*                            (продолжить обработку обмена)
	нед	Е15П1        , найти старший бит (номер нового
*                            терминала)
	уи	М16          , М16 := номер терминала
	мода	ttvt7        , вызвать ttvt7 – установить
	пв	(М17)        , будильник и отметить в ШКОРАБ
	сч	СЛОN         , список свободных логических
*                            номеров терминалов
	или	E48(М16)     , добавить бит данного терминала
	зп	СЛОN         , отметить как свободный (зачем? –
*                            временно, пока идёт инициализация)
	сч	шзпри7       , снять запрет приёма для данного
	или	E48(М16)     , терминала (разрешить приём)
	нтж	E48(М16)
	зп	шзпри7
	сч	новтер(М5)   , сбросить бит в шкале новых
	нтж	E48(М16)     , терминалов – он обслужен
	зп	новтер(М5)
	уиа	'3'          , разрешить прерывания
	пб	обдкс8       , продолжить цикл для оставшихся
*                            новых терминалов
*
* ЗАГР. ПРИ НАПР. КРК=0
***** БЛОК ОБРАБОТКИ ИНФ. ЧЕРЕЗ АС ДКС
***** В АВТОМАТИЧ. РЕЖИМЕ
*
* ЗАГР. ПРИ НАПР. КРК=0
трмдкс	уиа	'2003' !Из навых или ИЗ АВТ. ЭКО
*                           , блокировка прерываний
	сч	обме7б       , загрузить шкалу быстрого обмена
	по	СВЯЗЬ7       , если пусто – выйти в начало
	нед	Е15П1        , найти старший бит (направление)
	уи	М5           , М5 := номер направления КРК
	сч	обме7б       , сбросить бит в шкале быстрого
	нтж	E48(М5)      , обмена для данного направления
	зп	обме7б
	уиа	25(М15)      , М15 := 25 – смещение для первого
*                           свободного абонента?
	сч	E48-1(М15)  24 РАЗРЯД , маска для 24-го разряда
	или	шзагс7       , установить глобальный признак
	зп	шзагс7       , активности СВЯЗЬ7
	сч	туsаб(М15)   , загрузить описатель S‑абонента
	и	О12П9        , очистить поле типа/кода
	зп	туsаб(М15)   , обновить (сбросить старый код)
	мода	кодтип       , по таблице кодтип (КОНФУС)
	сч	(М5)         , загрузить тип для направления М5
	сда	64-8         , сдвинуть в позицию поля типа
	или	туsаб(М15)   , вставить в описатель абонента
	зп	туsаб(М15)   , сохранить обновлённый описатель
	сда	64+8         , выделить вставленный байт
	и	П7           , оставить 3 бита (номер режима)
*
	кк	26,'70000' !132,0 ПРИ НАПР. КРК=0
*                           , запись в буфер КАДОПАМ (команда
*                           , для нулевого направления КРК)
*!ЗДЕСЬ ЦИКЛИМСЯ ЕСЛИ N НАПР. КРК=0.
* !МАСКА 7707 NNNN NNNN NNN2
*
	счи	М5           , загрузить номер направления
	нтж	E2           , проверить: не равно ли 2?
	по	номнпр       , если 2 → номнпр (особый случай)
	нтж	П3           , проверить: не равно ли 3?
	пе	запрос !НАПР. КРК=0 , если не 3 → к запрос
* EСЛИ НОМ. НАПР. ДКС <> 0
номнпр	кк	26,'2' !032,2 - !МАСКА 7707 NNNN NNNN NNNN
*                           , чтение из буфера КАДОПАМ (032,2)
	зп	nнпкрк       , сохранить прочитанное слово
	мод	адркс1       , адрес для чтения счётчика прерыв.
	кк	26,'0' !СЧЕТЧИК ПРЕРЫВАНИЯ ИСТОЧНИКА
*                           , чтение счётчика прерыв. источника
* !МАСКА 7707 NNNN NNNN NNNN
	сда	64+24        , выделить старшие 24 разряда
	зп	экояч1       , сохранить в экояч1 (КОНФУС)
*
*** ДЕШИФРАТОР ЗАПРОСОВ ОТ Э-60
*
запрос	счи	М5  НОМЕР НАПР КРК , загрузить номер направления
	нтж	всеед7       , сравнить с -1 (все направления)
	по	рспец        , если все → особый случай (рспец)
	уии	М16(М5)      , иначе М16 := номер направления
	слиа	-3(М16)      , вычесть 3 – проверка на напр. 0?
	мода	зпрос1  !НАПР. КРК =0 , если направление 0 →
*                           переход к зпрос1
	пино	(М16) !УХОД НА зпрос1
	сч	режим7(М5)   , загрузить шкалу абонентов напр. М5
	по	трмдкс       , если пусто → вернуться к трмдкс
	мода	абуфs        , таблица адресов буферов S‑машин
	сч	(М5)         , загрузить адрес буфера для напр. М5
	уи	М16 АДРЕС БУФЕРА S-ТЕРМИНАЛА , М16 := адрес
	кк	26,'1'(М16)  , чтение счётчика прерываний
*                           получателя из буфера S‑терминала
	зп	отдкс1       , сохранить первое прочитанное слово
	кк	26,'2'(М16)  , чтение второго слова (идентификатор
*                           абонента)
	нтж	отдкс1       , сравнить с первым
	по	трмдкс       , если совпадают → буфер пуст, выйти
	кк	26,'0'(М16)  , чтение счётчика прерываний источника
	сда	64+24        , выделить старшие 24 разряда
	уи	М2 НОМЕР АБОНЕНТА , М2 := номер абонента (0..47)
	вч	П40          , проверить на превышение 40
	пе	трмдкс       , если >40 → выйти
	вч	П20          , проверить на <20
	по	трмдкс       , если <20 → выйти
	сч	режим7(М5)   , проверить, зарегистрирован ли
	и	E48-1(М2)    , абонент в шкале направления
	по	трмдкс       , если нет → выйти
	сч	шкаэко       , проверить шкалу ЭКО (ВЗУ)
	и	E48-1(М2)    , бит данного абонента
	мод	базэко       , если установлен →
	пе	прцес1-ЭКО !В ЭКО , переход в ЭКО для обработки
	сч	отдкс1       , иначе загрузить первое слово снова
	сда	64+24        , выделить старшие 24 разряда
	кк	26,'70002'(М16) , записать подтверждение в буфер
	мода	трмдкс       , адрес возврата = трмдкс
	уиа	0(М16)       , М16 := 0
	счи	М2           , загрузить номер абонента
	или	E26 НОМБОБ   , добавить код события E26 (НОМБОБ)
	пб	ЗАПВЕТ       , установить событие для задачи
*                           (активировать НОМБОБ)
*
зпрос1	сч	ручной = 46Р. для ЭВМ №3 , проверить ручной
	и	E48(М5)      , режим для направления М5
	по	непоня !НАПР. КРК=0 , если не ручной → непоня
	мода	(М5)         , ручной режим: адрес буфера
	мод	абуфs        , для направления М5
	кк	26,'1' СЧЕТЧИК ПРЕРЫВАНИЯ ПОЛУЧАТЕЛЯ.
*                           , чтение счётчика прерываний
	сда	64+24        , выделить старшие 24 разряда
	зп	отдкс1       , сохранить
	мода	масотв       , маска ожидаемого ответа
	и	(М5)         , для направления М5
	нтж	отдкс1       , сравнить с прочитанным
	пе	непоня НЕ НАШЕ ПРЕРЫВАНИЕ(?) , если не совпало
*                           → непоня (игнорировать)
	пб	завобр       , иначе → к завершению обработки
обраб	уиа	'3'          , разрешить прерывания
	сч	отдкс1       , загрузить сохранённое слово
	уи	М16          , М16 := адрес для следующего чтения
	мода	(М5)         , адрес буфера
	мод	абуфs
	кк	26,'2'(М16)  , чтение второго слова (идентификатор)
	сда	64+24
	уи	М2 НОМЕР АБОНЕНТА , М2 := номер абонента
	слиа	1(М16)       , увеличить адрес на 1
	счи	М16          , загрузить новый адрес
	мода	масотв
	и	(М5)         , маска ответа для направления
	зп	отдкс1       , сохранить
	слиа	-48(М2)      , проверить: абонент = 48 (ОС)?
	мода	ос  СИСТЕМНЫЙ ЗАПРОС ОТ S-МАШИНЫ
	пио	(М2)         , если 48 → системный запрос (ос)
	слиа	48(М2)       , восстановить номер абонента
	счи	М2           , загрузить номер
	вчоб	П60          , проверить, что <48
	пе	завобр       , если ≥48 → к завобр
	сч	режим7(М5)   , проверить, зарегистрирован ли
	или	новтер(М5)   , абонент в шкалах активных/новых
	и	E48-1(М2)
	по	завобр       , если нет → к завобр
	сч	новтер(М5)   , проверить, новый ли это терминал
	и	E48-1(М2)
	пе	sтрзпр       , если новый → sтрзпр (запрос от
*                           S‑терминала)
завобр	уиа	'3'          , разрешить прерывания
	мода	(М5)         , адрес буфера
	мод	абуфs
	кк	26,'0' СЧЕТЧИК ПРЕРЫВАНИЯ ИСТОЧНИКА
*                           , чтение счётчика прерыв. источника
	сда	64+24
	мода	масотв
	и	(М5)         , маска для направления
	нтж	отдкс1       , сравнить с сохранённым
	пе	обраб        , если не совпало → обраб (продолжить
*                           поиск)
	уиа	'2003'       , иначе блокировка прерываний
	сч	отдкс1       , загрузить сохранённое слово
	мода	(М5)
	мод	абуфs
	кк	26,'70001' !МАСКА 7707 , запись подтверждения
*                           в буфер
непоня	сч	режим7(М5)   , загрузить шкалу активных абонентов
	зп	СЧЕТПР+3     , сохранить в СЧЕТПР+3
снова	по	трмдкс ---> !МАСКА 7707 , если пусто → к трмдкс
	нед	              , найти старший бит
	уи	М2           , М2 := номер абонента
	или	E26          , добавить код события НОМБОБ
	пв	ЗАПВЕТ(М16)  , установить событие
	уиа	'3'          , разрешить прерывания
	сч	СЧЕТПР+3     , сбросить обработанный бит
	нтж	E48-1(М2)
	зп	СЧЕТПР+3     , обновить
	пб	снова        , продолжить цикл
*
*** СПЕЦИАЛЬНЫЙ РЕЖИМ РАБОТЫ
*
рспец	сч	nнпкрк        , загрузить прочитанное ранее слово
*                            (счётчик прерываний или состояние)
	сда	64+24          , выделить старшие 24 разряда
	и	П77            , оставить 6 бит (код состояния)
	по	трмдкс !НАПР. КРК=0. , если 0 → возврат к трмдкс
	нтж	П60            , сравнить с кодом 60₈ (ошибка?)
	по	плохо          , если 60₈ → плохо (ошибка)
	и	П3             , выделить младшие 2 бита
	уи	М2             , М2 := номер группы (0–3)
	нтж	П3             , проверить, не равен ли 3?
	по	трмдкс         , если 3 → выход
	сч	рабнст+1(М2)   , загрузить слово рабочей области
	и	маспец         , проверить маску спец. битов
	по	трмдкс         , если нет → выход
	или	nнпкрк         , иначе объединить с прочитанным
	зп	рабнст+1(М2)   , сохранить
	и	маспец         , снова выделить спец. биты
	нед	               , найти старший установленный бит
	уи	М2             , М2 := номер бита (абонент?)
	сч	E48-1(М2)      , сформировать маску абонента
	и	шкаэко         , проверить в шкале ЭКО (ВЗУ)
	мод	базэко         , база модуля ЭКО
* ДЛЯ ЗАПУСКА АВТ. ЭКО
	пе	прцс1а-ЭКО     , если бит установлен → переход в
*                            ЭКО для автоматической обработки
	мода	трмдкс         , иначе адрес возврата = трмдкс
	уиа	0(М16)         , М16 := 0
	сч	шкошиб         , проверить шкалу ошибок ДКС
	и	маспец         , выделить спец. биты
	по	трмдкс         , если нет ошибок → выход
	нед	               , найти бит ошибки
	или	E26            , добавить код события НОМБОБ
	пб	ЗАПВЕТ         , установить событие (активировать
*                            НОМБОБ для обработки ошибки)
*
плохо	сч	nнпкрк         , ошибочное состояние
	сда	64-4           , сдвинуть для анализа
	счмр
	пе	трмдкс         , если не 0 → выход
	зп	,               , (неясная запись, возможно обнуление)
	зп
	пб	трмдкс
*
*         ПРИШЛА КОМАНДА ОТ СИСТЕМЫ
*
ос	мода	(М5)           , обработка системного запроса
	мод	абфосs         , от S‑машины: чтение кода команды
	кк	26,'0'         , из буфера системных запросов
	сда	64+24
	и	П3             , выделить младшие 2 бита (код команды)
	по	завобр         , если 0 → к завобр (игнорировать)
	уи	М17  КОД КОМАНДЫ , М17 := код команды (1,2,3)
	мода	перекл         , диспетчер команд
	пб	-1(М17)        , переход по адресу перекл[М17-1]
*
перекл	пб	нтерм7         , команда 1: подключение нового терминала
	пам	0              , (разделитель)
	пб	завобр         , команда 2: ответ (освобождение)
	пам	0
	пб	отклтр         , команда 3: отключение терминала
*
*         ПОДКЛЮЧЕНИЕ НОВОГО ТЕРМИНАЛА
*
***************************************************
* нтерм7 – ПОДКЛЮЧЕНИЕ НОВОГО ТЕРМИНАЛА (КОМАНДА 1
* ОТ S‑МАШИНЫ). ВХОД: М5 – НОМЕР НАПРАВЛЕНИЯ КРК,
* новтер(М5) – ШКАЛА НОВЫХ ТЕРМИНАЛОВ.
* ПРОВЕРЯЕТ, НЕ ЗАНЯТА ЛИ ЛИНИЯ, ВЫБИРАЕТ
* СВОБОДНЫЙ ЛОГИЧЕСКИЙ НОМЕР (СЛОN), НАСТРАИВАЕТ
* ОПИСАТЕЛЬ АБОНЕНТА (туsаб) И ОТПРАВЛЯЕТ ОТВЕТ.
***************************************************
нтерм7  сч      новтер(М5)   , загрузить шкалу новых терм.
        зп      СЧЕТПР+3     , сохранить для цикла
нтер7а  сч      СЧЕТПР+3     , цикл: есть ли ещё новые?
        по      нтер7б       , если пусто → нтер7б
        нед     Е15П1        , найти старший бит
        уи      М16          , М16 := номер терминала
        сч      E48(М16)     , сбросить бит в рабочей шкале
        нтж     СЧЕТПР+3
        зп      СЧЕТПР+3
        сч      туsаб+1(М16) , загрузить описатель абонента
        сда     64-6         , выделить поле (сдвиг влево на 6)
        счмр                 , извлечь выдвинутые биты
        зп      СЧЕТПР+4     , сохранить в СЧЕТПР+4
        мода    (М5)         , чтение счётчика прерываний
        мод     абфосs       , получателя из буфера S‑машины
        кк      26,'1' !СЧЕТЧИК ПРЕРЫВАНИЯ ПОЛУЧАТЕЛЯ.
        сда     64+24
        и       П77          , оставить 6 бит (идентификатор)
        нтж     СЧЕТПР+4     , сравнить с сохранённым
        по      недстп ЛИНИЯ УЖЕ ЗАНЯТА , совпадает → занята
        пб      нтер7а       , иначе продолжить
*
нтер7б  сч      СЛОN         , список свободных лог. номеров
        или     E1           , добавить бит 1 (заглушка)
        нтж     E1           , сбросить его
        по      ответ1       , если пуст → нет свободных
        нед     Е15П1        , найти старший свободный номер
        уи      М16          , М16 := новый лог. номер терм.
        уиа     '2003'       , блокировка прерываний
        сч      E48(М16)     , маска нового терминала
        или     новтер(М5)   , добавить в шкалу новых терм.
        зп      новтер(М5)   , (пометить как "новый")
        сч      E48(М16)     , занять номер в СЛОN
        нтж     СЛОN
        зп      СЛОN
        сч      E48(М16)     , запретить приём (пока не обслужен)
        или     шзпри7
        зп      шзпри7
        сч      E48(М16)     , отметить в шкале прямых терм.
        или     ШКУСТР
        зп      ШКУСТР
        сч      ШКАЛ         , отметить в шкале видеотонов
        или     E48(М16)     , (ШКАЛ – синоним ШКВИД)
        зп      ШКАЛ
        сч      туsаб+1(М16) , загрузить описатель абонента
        и       D47127       , очистить поле номера машины
        зп      туsаб+1(М16)
        счи     М5           , вставить номер направления КРК
        сда     64-4
        или     туsаб+1(М16)
        зп      туsаб+1(М16) НОМЕР МАШИНЫ
        мода    (М5)         , прочитать из буфера S‑машины
        мод     абфосs
        кк      26,'1' !СЧЕТЧИК ПРЕРЫВАНИЯ ПОЛУЧАТЕЛЯ.
        сда     64-18        , сдвинуть в поле адреса области
        или     туsаб+1(М16) , добавить к описателю
        зп      туsаб+1(М16) .ОПИСАТЕЛЬ АБОНЕНТА S-МАШИНЫ
        мода    (М5)         , ещё раз из буфера S‑машины
        мод     абфосs
        кк      26,'2'       , чтение второго слова (адрес области)
        сда     64+25        , выделить разряды 26-48?
        и       Е15П1        , маска
        сда     64-24        , сдвинуть обратно
        или     туsаб+1(М16) , добавить к описателю
        зп      туsаб+1(М16) .АДРЕС ОБЛАСТИ АБОНЕНТА
        пв      ПИЛОТ(М15)   , вызов ПИЛОТ (МОТТ) – инициировать
*                               выдачу приглашения новому терм.
        счи                  , очистить СМ
        зп      яответ       , яответ := 0 (успех)
*
***************************************************
* ответ – ОТПРАВКА ОТВЕТА S‑МАШИНЕ ПОСЛЕ
* ОБРАБОТКИ КОМАНДЫ. М5 – НАПРАВЛЕНИЕ,
* яответ – КОД ОТВЕТА (0 – УСПЕХ, 1 – ЗАНЯТО,
* 2 – ОШИБКА). ПЕРЕХОДИТ К прервs ДЛЯ
* УВЕДОМЛЕНИЯ МИКРО‑ЭВМ.
***************************************************
ответ   слиа    1(М16)       , М16 := лог. номер + 1
        счи     М16 НОМЕР ТЕРМИНАЛА , загрузить номер
        мода    (М5)         , записать в буфер системных
        мод     абфосh       , запросов H‑машины
        кк      26,'70001'   , запись первого слова ответа
        сч      яответ       , загрузить код ответа
        мода    (М5)
        мод     абфосh
        кк      26,'70002'   , запись второго слова ответа
        сч      E2 КОД КОМАНДЫ , код 2 (подтверждение)
        мода    (М5)
        мод     абфосh
        кк      26,'70000'   , запись команды в буфер H‑машины
        уиа     48(М2) .НОМ АБОНЕНТА - ОС , установить М2=48
        уии     М15(М5)      , М15 := номер направления
        мода    завобр       , адрес возврата = завобр
        уиа     0(М17)       , М17 := 0
        пб      прервs       , вызов прервs – отправить
*                               прерывание в S‑машину
***************************************************
* ответ1 – НЕТ СВОБОДНЫХ ЛОГИЧЕСКИХ НОМЕРОВ
***************************************************
ответ1  уи      М16          , М16 := 0 (заглушка)
        сч      E2           , код 2 (ошибка)
        зп      яответ       , сохранить код ошибки
        пб      ответ        , отправить ответ

***************************************************
* недстп – ЛИНИЯ УЖЕ ЗАНЯТА (ОТВЕТ С КОДОМ 1)
***************************************************
недстп  сч      E1    !ЕСЛИ ЛИНИЯ НЕ ДОСТУПНА , код 1
        зп      яответ       , сохранить
        пб      ответ        , отправить ответ

***************************************************
* отклтр – ОТКЛЮЧЕНИЕ ТЕРМИНАЛА (КОМАНДА 3).
* ОСВОБОЖДАЕТ ЛОГИЧЕСКИЙ НОМЕР, СНИМАЕТ
* ЗАПРЕТ ПРИЁМА, УСТАНАВЛИВАЕТ БУДИЛЬНИК.
***************************************************
отклтр  мода    (М5)         , чтение из буфера S‑машины
        мод     абфосs
        кк      26,'1' !СЧЕТЧИК ПРЕРЫВАНИЯ ПОЛУЧАТЕЛЯ.
        сда     64+24
        и       П77          , выделить номер терминала
        уи      М16          , М16 := номер отключаемого
        слиа    -1(М16)      , скорректировать (терм. с 0)
        сч      новтер(М5)   , проверить, есть ли в новых
        и       E48(М16)
        по      завобр       , если нет → выйти
        нед     Е15П1        , найти старший бит (проверка)
        и       Е15П1
        зп      СЧЕТПР+3     , сохранить
        счи     М16          , сравнить с отключаемым
        нтж     СЧЕТПР+3
        пе      завобр       , не совпадает → выйти
        уиа     '2003'       , блокировка прерываний
        сч      E48(М16)     , сбросить бит в шкалах
        нтж     ВСЕЕД        , инвертировать маску
        зп      рприем       , сохранить инверсную маску
        и       новтер(М5)   , сбросить бит в новых
        зп      новтер(М5)
        сч      СЛОN         , вернуть номер в свободные
        или     E48(М16)
        зп      СЛОN
        сч      шзпри7       , снять запрет приёма
        и       рприем
        зп      шзпри7
        мода    ttvt7        , вызов ttvt7 – установить
        пв      (М17)        , будильник
        уиа     '3'          , разрешить прерывания
        пб      завобр

***************************************************
* sтрзпр – ЗАПРОС ОТ S‑ТЕРМИНАЛА (КОМАНДЫ 4,5,6).
* М2 – НОМЕР АБОНЕНТА, М10 – АДРЕС ИНФ. ПОЛЯ.
* КОД 4 – ПРИЁМ МАССИВА, 5 – ЗАВЕРШЕНИЕ ВЫДАЧИ,
* 6 – ОТКЛЮЧЕНИЕ. ПЕРЕХОДИТ К СООТВЕТСТВУЮЩЕЙ
* ПРОЦЕДУРЕ.
***************************************************
sтрзпр  сч      туsаб(М2)    , загрузить описатель абонента
        сда     64+24        , выделить адрес инф. поля
        и       Е15П1        , (младшие 15 бит)
        уи      М10 АДР. ИНФ. ПОЛЯ ТЕРМИНАЛА , М10 := адрес
        кк      26,'2'(М10)  , чтение второго слова (код)
        сда     64+24
        и       П7           , оставить 3 бита (код команды)
        уи      М17 КОД КОМАНДЫ , М17 := код (1..6)
        слиа    -4(М17)      , проверить код 4 (приём)
        мода    ввдsтр       , массив от S‑терминала
        пио     (М17)        , если 4 → ввдsтр
        слиа    -1(М17)      , проверить код 5 (завершение)
        мода    выднаs       , выдачи на S‑терминал
        пио     (М17)        , если 5 → выднаs
        слиа    -1(М17)      , проверить код 6 (отключение)
        мода    завобр
        пино    (М17)        , если 6 → завобр (игнорировать)
        уиа     '2003'       , иначе код <4: установить
        сч      ТСЛ-1(М2)    , бит "звонок" в ТСЛ терминала
        или     E19
        зп      ТСЛ-1(М2)
*
*
***         ЗАВЕРШЕНА ВЫДАЧА НА S-ТЕРМИНАЛ
*
выднаs	слиа	-1(М2)         , скорректировать номер терм.
	мода	завобр          , адрес возврата после обработки
	уиа	0(М16)          , М16 := 0
	уиа	'2003'          , блокировка прерываний
	сч	E48(М2)         , сбросить бит выдачи в ШКВЫД
	или	ШКВЫД
	нтж	E48(М2)
	зп	ШКВЫД
	сч	E48(М2)         , разрешить приём (снять запрет)
	или	ШЗПРИМ
	нтж	E48(М2)
	зп	ШЗПРИМ
	уии	М15(М2)         , М15 := номер терминала
	кк	26,'1'(М10)     , чтение первого слова из инф. поля
	сда	64+24           , выделить старшие 24 разряда
	и	масsтр          , маска статуса S‑терминала
	кк	26,'70001'(М10) , записать подтверждение в инф. поле
	счи	                , очистить сумматор
	зп	ТАС+1(М2)       , сбросить второй элемент ТАС
	пб	КВ2 !МОТТ. ЗАВЕРШ. ВЫДАЧИ И ВЫД. ПРИГЛ.
*                           , переход к КВ2 (МОТТ) – завершить
*                           выдачу и выдать приглашение
*
*         ВОЗЬМИ МАССИВ С S-ТЕРМИНАЛА
*
ввдsтр	слиа	-1(М2)         , номер терминала для индексации
	уии	М17(М2)         , сохранить М2 в М17
	мод	ТБЛ(М2)         , получить адрес начала рекорда
	уиа	0(М16)          , М16 := адрес рекорда
	уиа	'2003'          , блокировка прерываний
	сч	ШЗПРИМ          , проверить запрет приёма
	и	E48(М2)
	по	вводсs          , если приём разрешён → вводсs
	кк	26,'0'(М10)     , иначе чтение первого слова инф. поля
	сда	64+24
	и	масsтр          , маска статуса
	кк	26,'70000'(М10) , записать статус "занято" в инф. поле
	пб	завобр          , и выйти
вводсs	сч	ТСЛ(М2)         , установить биты "приём" (Е28) и
	или	E28             , "не возвращать каретку" (Е31)
	или	E31
	зп	ТСЛ(М2)         , обновить ТСЛ терминала
	уиа	'3'             , разрешить прерывания
	кк	26,'3'(М10)     , чтение адреса буфера S‑терминала
	сда	64+25           , выделить разряды 26-48
	уи	М13  АДРЕС БУФЕРА S-ТЕРМИНАЛА , М13 := адрес буфера
	сч	ТСЛ(М2)         , выделить тип кодировки (бит 36?)
	сда	64+36
	и	E1
	уи	М11             , М11 := признак кодировки (0 или 1)
	уиа	'3'             , разрешить прерывания
ввдcs1	кк	26,'0'(М13)     , чтение слова из буфера S‑терминала
	сда	64+24           , выделить старшие 24 разряда
	зп	рприем          , сохранить принятое слово
	уиа	-1(М3)          , М3 := -1 (счётчик байт в слове)
ввдcs2	и	П377            , выделить младший байт (символ)
	уи	М15             , М15 := код символа
	зп	символ          , сохранить в ячейке символ
	по	конмас КОНЕЦ МАССИВА , если 0 → конец массива
	мода	цклпрм          , если М11≠0 – перекодировка
	пино	(М11)           , (признак кодировки) → цклпрм
	сч	ТАБКОД(М15)     , перекодировка через ТАБКОД (ТЕРМ)
	сда	64+8            , выбрать нужный байт
	и	П377
	зп	символ          , сохранить перекодированный символ
цклпрм	мод	(М16)           , додвижка символа в рекорд:
	сч	9(М16) ДОДВИЖКА , загрузить текущее слово рекорда
	сда	64-8            , сдвинуть влево
	или	символ          , вставить символ
	пв	ЗПСЕС1(М14)     , записать в рекорд (МОТТ)
	мод	ТБЛ(М2)         , обновить адрес начала рекорда
	уиа	0(М16)          , М16 := новый адрес рекорда
	сч	рприем          , загрузить оставшуюся часть слова
	сда	64+8            , сдвинуть вправо на 8 бит
	мода	ввдcs2          , продолжить цикл по байтам
	цикл	(М3)   !        , пока не обработаны все байты
	слиа	1(М13)          , перейти к следующему слову буфера
	пб	ввдcs1          , продолжить чтение
конмас	сч	П3              , загрузить код 3 (ETX?)
	зп	рприем          , сохранить как признак конца
