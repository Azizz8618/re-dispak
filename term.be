****** НАСТРОЙКА ПО ТИПУ ТЕРМИНАЛА ******
*
ДЛЯЭ71 НОП                 , точка входа для Э71ТК
	мод	ТБЛ(М2)     , М1 := адрес рекорда данного
	уиа	9(М1)       , терминала (9-е слово рекорда)
	сч	ТСЛ(М2)     , загрузить таблицу состояния линии
	сда	64+12       , выделить код устройства (разряды
	и	Е6П4        , 16–18) маской 6–4
	уи	М6          , М6 = код устройства (сдвиг ТАБКОД)
	слиа	-48(М6)     , вычесть 48
	пио	ш5(М6)      , если 0 → ш5 (ВТ-340 или ТТ)
	и	П30         , иначе проверить маску 30₈
	уи	М6          , М6 = тип (8 – ВТ, 0 – ТТ?)
	слиа	-8(М6)      , вычесть 8
