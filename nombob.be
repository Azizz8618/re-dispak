********** БЛОК РАБОТЫ ДЛЯ К-71 ***********
* АС К-71. ВЫДАЧА ДИАГНОСТИЧЕСКИХ СООБЩЕНИЙ
***
диасм7	пам	0               , начало блока К‑71
	сч	рсвсм1         , загрузить регистр связи
*                        (если <>0 – тестовый режим)
	по	нстдкс         , если 0 → стандартный режим
	нед	П77777         , найти старший бит (номер)
	уи	М16            , М16 := номер сообщения
	и	П77777         , выделить код сообщения
	сда	64-24          , сдвинуть в позицию
	или	ткcм7б         , добавить текст "К:0 СМ"
	зп	ткcм7а         , сохранить в буфере сообщения
	сч	рсвсм1         , загрузить ещё раз
	нтж	E48(М16)       , сбросить обработанный бит
	зп	рсвсм1         , обновить регистр
	сч	рсвясм(М16)    , загрузить слово связи
	сда	64-6           , сдвинуть для выделения
	рзб	шесть7         , разобрать по маске (6 бит)
	зп	пробел         , сохранить в буфере
	мода	ткчкр7         , адрес текста "КЧ КР"
	уиа	0(М16)         , М16 := 0
	мода	диасм7         , адрес возврата
	уиа	0(М15)         , М15 := 0
