	и	31(М11)      , проверить флаги в зоне
	пе	оч2а         , если есть → к оч2а
	мода	(М14)        , иначе очистить зону
	зп	31(М11)      , записать 0
	пб	оч2          , переход к оч2
оч2а	мода	(М14)        , загрузить зону
	сч	31(М11)      , загрузить запись
	нтж	НОВД+3       , сравнить с эталоном
	и	е30п28       , маска даты
	пе	оч2          , если не совпадает → оч2
	счи	М13          , загрузить индекс зоны
	сда	64-8         , сдвинуть для вставки в текст
	или	т1           , добавить шаблон "ВКЛЮЧ"
	зп	т10+3        , сохранить в буфере сообщения
	уии	М17(М11)     , М17 := номер зоны
	слиа	'67'(М17)    , добавить 67₈ (смещение)
	счи	М17          , загрузить абсолютный номер
