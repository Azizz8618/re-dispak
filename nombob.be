	сда	64-5         , сдвинуть для индексации
	уи	М14          , М14 := индекс
	сли	М14(М3)      , абсолютный адрес
	уиа	-31(М11)     , М11 := -31 (цикл по зонам)
	пб	чи1          , переход к чи1
***************************************************
* ЭТОТ – ПОИСК ЗАДАЧИ, КОТОРОЙ ПРИНАДЛЕЖИТ
* ДАННАЯ МЛ (ПО СТРОКЕ И СТОЛБЦУ ОБЩТОМ).
* ВХОД: М2 – НОМЕР СТРОКИ, М4 – НОМЕР СТОЛБЦА
* В ОБЩТОМ. РЕЗУЛЬТАТ: ПЕРЕХОД К ЭТЛЕ, ЕСЛИ
* НАЙДЕНА ОБЩАЯ МЛ, ИНАЧЕ К ПО2.
***************************************************
ЭТОТ СЧИ М2               , загрузить номер строки
 СЛЦ П3                   , добавить 3 (размер элемента)
 СДА 64-2                 , сдвинуть для индексации
 ЗП Р                     , сохранить в Р
 СЧИ М4                   , загрузить номер столбца
 СЛЦ П3                   , добавить 3
 ИЛИ Р                    , объединить со строкой
 ЗП Р НОМ СТР,СТОЛБЦА ОБЩТОМ , сохранить полный индекс
 УИА -15(М13)             , М13 := -15 (цикл по 16 БЭСМ)
ЭТТ УИА 4(М10)            , М10 := 4 (число попыток?)
ЭТД МОДА (М11)            , адрес ИПЗ задачи
 СЧ ШЗНМБ+15(М13)         , загрузить шкалу занятости МБ
*                            (смещение 15 от ШЗНМБ)
 СДА 64+8(М10)            , сдвинуть для выделения байта
 НТЖ Р                    , сравнить с индексом
 И П17                    , маска (5 бит)
 ПО ЭТДИ                  , если совпадает → к ЭТДИ
 МОДА ЭТД1                , адрес для следующей итерации
 ПИО (М10)                , если М10=0 → к ЭТД1
 УИА (М10)                , иначе обнулить М10
 ПБ ЭТД                   , продолжить поиск
ЭТД1 МОДА ЭТТ             , цикл по БЭСМ
 ЦИКЛ (М13)
ЭТДИ СЛИА 15(М13)         , найден совпадающий индекс
 СЛИ М13(М13)             , умножить на 2
 МОДА ЭТЛЕ                , адрес возврата
 ПИО (М10)                , если М10=0 → к ЭТЛЕ (общая МЛ)
 СЛИА 1(М13)              , иначе скорректировать индекс
 ПБ ЭТЛЕ                  , переход к обработке общей МЛ
***************************************************
* ВЫХ – ЗАВЕРШЕНИЕ ОБРАБОТКИ МЛ ПРИ ПЕРЕСТАНОВКЕ.
* ЕСЛИ НЕТ НОВЫХ МЛ – ВЫХОД, ИНАЧЕ ПРОДОЛЖЕНИЕ.
***************************************************
ВЫХ СЧ ВРЕЗП              , загрузить счётчик времени
 СЛЦ Е42        свс: Е43  , добавить интервал (Е42 или Е43)
 УИА 1027                 , блокировка прерываний
 ПЕ СТАТ                  , если не истекло → к СТАТ
СТАТ1 НОП ,               , вход при истечении времени
* СЧ ЗАНЯТА
* И Е7
* ПО В             НЕ НАБРАНА ДИРЕКТИВА ’ВРЕ’
 МОДА НАЧСТ-УН(М7)        , адрес начала статистики
 УИА (М16)                , М16 := 0
* СЧ ’5000’
 УИА КУСПН-Н(М5)          , КУС для вызова статистики
 ПБ ВЫЗАСЧ       ВЫЗОВ И ПЕРЕХОД В СТАТ1
КНЦСТ МОДА СТАСУТ-УНТ(М7) , адрес завершения статистики
 УИА (М16)                , М16 := 0
        счи     м7        , загрузить базу модуля (М7)
        сда     64-2      , сдвинуть для формирования КУС
        или     кусп5     , добавить КУС для СТАТ2Б
        или     номмб     , добавить номер МБ
        пб      физобм    , физический обмен (чтение) с МБ
КНЦСТТ СЧ 0               , очистить СМ
СТАТ ЗП ВРЕЗП             , сбросить счётчик времени
*В
 СЧ ВРЕМЯ                 , загрузить текущее время
 ВЧАБ БУДСМЕ              , сравнить с будильником СМЕ
 ВЧАБ КОН                 , и с константой КОН
 ПЕ ВОЗ1                  , если не вышло → ВОЗ1
 СЧ ШКИВ                  , иначе установить бит E25
 ИЛИ Е25                  , (вызов ПРИКАЗ)
 ЗП ШКИВ
 СЧ Е3                    , загрузить 3
 ЗП ТУМБ6                 , сохранить в ТУМБ6 (номер директивы)
 СЧ ВРЕМЯ                 , обновить будильник СМЕ
 ЗП БУДСМЕ
ВОЗ1 СЧ 0                 , очистить СМ
 ЗП ПРЗП                  , сбросить признак записи на МД
 ПБ ЗВ2                   , вернуться к проверке зависания
*
 ЛИТЕР                    , начало области текстовых констант
