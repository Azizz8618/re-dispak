        сч                 , очистить СМ
        зп      ШОЧМГ(М4)  , обнулить очередь МГ (может ШОЧМГ)
        пб      по6        , переход к по6 (свс: НВМЛ1)
***************************************************
* ЭТЛЕ – ПРОВЕРКА ДЛЯ ОБЩИХ ЛЕНТ ПРИ ПЕРЕСТАНОВКЕ.
* ЕСЛИ МЛ НЕ ОБЩАЯ – ПРОПУСК.
* ВХОД: М11 – АДРЕС ЗАПИСИ ОБЩИХ ЛЕНТ,
* М15 – НОМЕР МЛ? М16 – НАПРАВЛЕНИЕ.
***************************************************
ЭТЛЕ СЧ УКАЗД(М11)        , загрузить указатель задачи из
*                            ИПЗ (40-е слово, УКАЗД)
 И Е32(М13)                , проверить бит 32 (признак МД?)
 ПЕ ПО3 МД                 , если установлен → это МД,
*                            переход к ПО3
 СЧ Р3-Н(М15)              , загрузить запись нового МГ
 СД КТОМЛ+2(М4)            , сдвинуть по маске КТОМЛ
 ЗП Б1+7                   , сохранить в Б1+7
	сч	Р1            , проверить, есть ли доп. запрос
	по	этали         , если нет → этали
	сч	ОБЩМЛ(М11)   , загрузить шкалу общих МЛ задачи
	сда	64(М16)      , сдвинуть для выделения бита ЭВМ
	мода	(М7)         , база НОМБОБ
	нтж	НОВД+2-Н(М17), сравнить с новым номером БЭСМ
	и	П7            , маска номера ЭВМ
	пе	ПО3           , если не совпадает → ПО3
	счи	М16           , загрузить номер направления
	вчоб	              , инвертировать (дополнение)
	уи	М17           , М17 := дополнение
	сч	НОВД+2-Н(М15), загрузить новый номер БЭСМ
	сда	64(М17)      , сдвинуть для установки
	зп	Р             , сохранить в Р
	сч	П7            , загрузить маску П7
	сда	64(М17)      , сдвинуть для формирования маски
	нтж	ВСЕЕД         , инвертировать (очистить поле)
	и	ОБЩМЛ(М11)   , выделить текущую шкалу
	или	Р	НОВАЯ ЭВМ , вставить новый номер БЭСМ
	зп	ОБЩМЛ(М11)   , обновить шкалу общих МЛ
ЭТЛ СЧ П77                 , загрузить маску П77
 СД КТОМЛ+2(М4)            , сдвинуть по маске КТОМЛ
 НТЖ ВСЕЕД                 , инвертировать (маска "не поле")
 МОДА (М11)                , адрес ИПЗ задачи
 И ОБЩТОМ+3(М2)            , выделить поле в ОБЩТОМ
 ИЛИ Б1+7                  , добавить новое значение
 МОДА (М11)
 ЗП ОБЩТОМ+3(М2)           , обновить ОБЩТОМ задачи
 ПБ ПО2                    , вернуться к циклу ПО2
этали	сч	ОБЩМЛ(М11)   , загрузить шкалу общих МЛ
	сда	64(М16)      , выделить бит для данной БЭСМ
	и	П7            , маска номера
	по	ЭТЛ           , если 0 → обычная обработка
	пб	ПО3           , иначе → ПО3 (уже есть общая)
***************************************************
* просто – ПРОВЕРКА НЕОБХОДИМОСТИ ЗАПУСКА ОБМЕНА
* ДЛЯ ПРОСТАИВАЮЩИХ МЛ.
* ВХОД: общ – ПРИЗНАК ОБЩИХ ЛЕНТ.
***************************************************
просто 	сч	общ         , загрузить признак общих лент
	по	НВМЛ4        , если нет → к НВМЛ4
	сч	ВРЕМЯ        , иначе проверить время
	вчаб	БУДЗП        , сравнить с будильником ЗП
	вчаб	ВР3М         , и с интервалом 3 минуты
	по	заказ1       , если время вышло → заказ1
	сч	ЗАНЯТА       , проверить шкалу занятости
	и	E47           , бит E47 (директива ВРЕ)
	по	заказ1       , если не установлен → заказ1
НВМЛ4 ПАМ                 , резервная ячейка
 СЧ СМЕМЛ                  , загрузить шкалу ожидания обмена
*                            с МЛ (СМЕМЛ)
 ИЛИ ВЫМГ                  , добавить шкалу выдачи МГ
 ПО ЗАНИ                   , если обе пусты → ЗАНИ
 УИА 1027                  , блокировка прерываний
 СЧ ШЗЗОБМ                 , загрузить шкалу задержки обмена
*                            с МЛ
 ПЕ ЗАН1                   , если не 0 → ЗАН1
 СЧ Е39                    , загрузить код события Е39
 ПВ ВШГ(М15)               , установить в системную шкалу
*                            готовности (ШГ)
 УИА ВХСМЕ(М16)            , адрес процедуры ВХСМЕ (БОЭК1)
 СЧИ М16                   , загрузить адрес
 ЗП ИПЗМЛ+3                , сохранить в 3-м слове ИПЗ МЛ
*                            (адрес возврата)
 СЧ 0                      , очистить СМ
ЗАН1 ИЛИ Е1                , установить бит 1 в задержке
 ЗП ШЗЗОБМ                 , сохранить в шкале задержки
*                            обмена с МЛ
ЗАНИ УИА 3                 , разрешить прерывания
 ПБ ПОИС6-Н(М7)            , переход к ПОИС6 (завершение
*                            обработки МЛ)
***************************************************
* вз2 – ПРОВЕРКА ЗАНЯТОСТИ МД ПРИ ПЕРЕНОСЕ ТЗНМЛ
* НА МД. ЕСЛИ МД СВОБОДЕН – ПЕРЕХОД К ЗАПИСИ.
* ВХОД: М3 – БАЗА ТАБЛИЦЫ НТЗНМЛ, НОВД – НОВЫЙ НОМЕР.
***************************************************
вз2	сч	ТЗНМД(М3)   , загрузить запись о занятости МД
	мод	НОВД         , модифицировать по новому номеру
	и	Е48-1        , проверить бит занятости
	по	вызсм3       , если свободен → вызсм3
н2	мода	н1           , иначе адрес возврата = н1
	пв	(М17)        , вызвать н1 (перенос ТЗНМЛ на МД)
вызсм3	мода	заказы-У3(М7), адрес процедуры заказы в СМЕНА3
	уиа	0(М16)       , М16 := 0
	уиа	КУСНЕР-Н(М5) , КУС для вызова нерезидента СМЕНА3
	пб	ВЫЗАСЧ в СМЕНА3 , переход к вызову СМЕНА3
***************************************************
* рабди – ОБРАБОТКА ЗАКАЗОВ ОТ СМЕНЫ3.
* ЕСЛИ ЕСТЬ ЗАКАЗЫ – ЗАПУСКАЕТ ОБМЕН С МД.
***************************************************
рабди	сч	НЗ ИЗ СМЕНЫ3 , загрузить наличие заказов
	или	НЗ+1         , проверить оба слова
	по	НВМЛ4        , если нет → к НВМЛ4
	сч	кробш        , загрузить шкалу ожидания
	и	Е48П42       , выделить биты 42-48
	уиа	'2003'       , блокировка прерываний
	по	рбб          , если 0 → к рбб
	или	РАОБЩ        , иначе добавить в общую шкалу
	зп	РАОБЩ        , сохранить
	сч	НОММЛ1       , загрузить номер МЛ
	уиа	3(М16)       , М16 := 3 (признак направления?)
	и	E42          , проверить бит E42
	по	рб           , если 0 → рб
	уиа	4(М16)       , иначе М16 := 4
рб	уии	М10(М6)      , сохранить М6 в М10
	пв	ОСВУ(М6)     , вызов ОСВУ (освобождение устр.)
	уии	М6(М10)      , восстановить М6
рбб	сч	РАОБЩ        , загрузить общую шкалу
	и	Е48П25       , очистить лишние разряды
	зп	РАОБЩ        , сохранить
	пб	НВМЛ4        , переход к НВМЛ4
***************************************************
* НВМЛ4А – ПРОВЕРКА ОБЩИХ ЛЕНТ ПЕРЕД ПЕРЕНОСОМ.
***************************************************
НВМЛ4А	сч	общ          , загрузить признак общих лент
	по	НВМЛ4        , если нет → к НВМЛ4
нвл1	мода	вз1          , адрес возврата = вз1
	уиа	0(М17)       , М17 := 0
н1	уиа	-31(М16)     , М16 := -31 (цикл по 32 зонам)
	сч	НОВД 	ПЕРЕНОС ТЗНМЛ НА МД
*                              загрузить НОВД (новый номер)
	уи	М10          , М10 := номер
	сда	64-5         , сдвинуть для индексации
И11	уи	М15          , М15 := индекс в таблице
	сч	ТЗНМД(М3)    , загрузить таблицу занятости МД
	или	Е48-1(М10)   , установить бит занятости
	нтж	Е48-1(М10)   , сбросить его (зачем?)
	зп	ТЗНМД(М3)    , обновить таблицу
	сли	М15(М3)      , вычислить адрес в таблице зон
	уии	М14(М15)     , М14 := адрес записи зоны
	сли	М10(М3)      , вычислить адрес в таблице МЛ
	сч	РМЛ          , загрузить режим МЛ
	зп	счзк(М10)    , сохранить в счётчик заказов
	сч	ЕС5017       , загрузить тип МЛ (ЕС-5017?)
	зп	кесмл1-1(М10), сохранить в таблице кесмл
***************************************************
* птз – ЦИКЛ ПЕРЕНОСА ЗОН МЛ НА МД.
* КОПИРУЕТ ЗАПИСИ ТЗНМЛ В ТАБЛИЦУ НА МД.
***************************************************
птз	сч	-32(М14)     , загрузить запись ТЗНМЛ
	и	ПРСВЛ        , проверить признак владельца
	сда	64+41        , выделить номер задачи
	нтж	П60          , сравнить с 60₈ (пусто?)
	по	птзо         , если пусто → к птзо
	сч	-32(М14)     , загрузить запись ещё раз
	и	E47          , проверить бит "занято"
	пе	птз1         , если занято → к птз1
	сч	-32(М14)     , загрузить запись
	нтж	E46          , инвертировать бит "общая?"
	по	птзс         , если общая → к птзс
	и	E14          , проверить бит "запись"
	пе	пт           , если есть → к пт
	сч	ВСЕЕД        , загрузить все 1
	нтж	е30п28       , маска для очистки даты
	и	ТЗНМД-1(М16) , выделить текущую запись
	зп	Р7           , сохранить в Р7
	сч	е30п28       , загрузить маску даты
	и	-32(М14)     , выделить дату из ТЗНМЛ
	или	Р7           , добавить к записи на МД
	зп	-32(М14)     , обновить
	сч	ТЗНМД-1(М16) , проверить бит 39
	и	E39
	по	пт           , если 0 → к пт
	сч	-32(М14)     , проверить дату в обновлённой
	и	е30п28       , записи
	по	пт           , если 0 → к пт
	сч	ТЗНМД-1(М16) , сбросить бит 39
	нтж	E39
	зп	ТЗНМД-1(М16) , обновить
пт	мода	(М16)        , загрузить номер МЛ из НТЗНМЛ
	сч	НТЗНМЛ+31   , загрузить запись
	и	П7777        , выделить номер МЛ
	зп	дтзн-32(М14) , сохранить в таблице на МД
	уиа	'3'          , разрешить прерывания
	пб	птз4         , переход к птз4
птз2	зп	-32(М14)     , сохранить запись на МД
	уиа	'3'          , разрешить прерывания
птз4	слиа	1(М14)       , увеличить адрес зоны
	мода	птз          , цикл по всем зонам
	цикл	(М16)
	пб	(М17)        , возврат (в н1 или вз1)
птз1	сч	сохр         , загрузить маску "сохр"
	и	-32(М14)     , выделить поле
птзс	зп	ТЗНМД-1(М16) , сохранить в таблице МД
	пб	птз2         , переход к птз2
птзо	уиа	'2003'      , блокировка прерываний
	сч	кробш        , загрузить шкалу ожидания
	или	Е48П42       , установить биты 42-48
	зп	кробш        , сохранить
	сч	сохра        , загрузить маску "сохра"
	или	E44          , добавить бит 44
	и	-32(М14)     , применить к записи
	пб	птзс         , переход к птзс
