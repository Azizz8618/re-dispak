***************************************************
вз1	пам	0            , резервная ячейка
	сч	ВРЕМЯ        , загрузить текущее время
	вчаб	БУДЗП        , сравнить с будильником ЗП
	вчаб	ВР3М         , и с интервалом 3 минуты
	пе	вз2          , если время не вышло → к вз2
	сч	ВРЕМЯ        , иначе обновить будильник
	зп	БУДЗП        , сохранить
	сч	общ          , загрузить признак общих лент
	уи	М4           , М4 := значение (0 или 1)
	уиа	1(М13)       , М13 := 1 (индекс зоны)
	уии	М14(М3)      , М14 := база таблицы (М3)
вз	уии	М11(М3)      , М11 := база таблицы
	сли	М11(М13)     , добавить индекс зоны
	сч	вр-1(М11)    , загрузить запись времени
	и	Е48-1(М13)   , проверить бит для данной БЭСМ
	по	взс          , если 0 → к взс
	нтж	вр-1(М11)    , иначе сбросить бит
	зп	вр-1(М11)    , обновить запись времени
