	сч	ШСВЯТ       , проверить шкалу связи ДКС
	и	E48(М2)
	пе	ЗАПР1        , если ДКС → не возвращать
	сч	шкут        , шкала терминалов через ДКС
	и	E48(М2)
	пе	ЗАПР4        , если ДКС → к ЗАПР4
******
	сч	ТСЛ(М2)     , выделить тип терминала
	сда	64+15
	и	П7
	уи	М15          , М15 := сдвиг для BREAK
	сч	BREAK0(М15)  , загрузить код BREAK
	зп	РЯРОТ
	сч	РЯ1          , проверить, был ли переполнен буфер
	по	вокар2       , если да → вокар2
	сч	РЯРОТ
	сда	64-24        , подправка константы
	по	ЗАПР1        , для консула возврат не нужен
	зп	РЯРОТ
