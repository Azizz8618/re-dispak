***************************************************
* МОДУЛЬ БОНБОТ – ОБРАБОТКА ДИРЕКТИВ ОПЕРАТОРА
* И УПРАВЛЕНИЕ ТЕРМИНАЛАМИ (НЕРЕЗИДЕНТ).
* АДРЕС ЗАГРУЗКИ 30000₈. ВЫЗЫВАЕТСЯ ПО Е30.
* ВКЛЮЧАЕТ ПОДКЛЮЧЕНИЕ ТЕРМИНАЛОВ, ВЫДАЧУ
* СООБЩЕНИЙ, ОБРАБОТКУ ПРИКАЗОВ.
***************************************************
БОНБОТ	СТАРТ	'30000'      , адрес загрузки модуля
	Е
	М
	употр	БОНБОТ(М7)  , М7 – база модуля
 КОНД В’0’                 , 0-е слово ИПЗ: СМ
 КОНД М41В’3’              , 1-е слово ИПЗ: РК=3
 КОНД (3)В’0’              , 2-4 слова ИПЗ: РМР, М33, М32
 КОНД М15В’3’В’3’М24В’2’  , 5-е слово ИПЗ: М27, М21
 КОНД (17)В’0’             , 6-22 слова: M20–M1 (17 слов)
 КОНД В’0’                 , 23-е слово ИПЗ (не занимать)
Н3724	КОНД М20В’77’М39В’1’М36В’1’В’-1’ , маска для ТСЛ
ТЕК2	конд	п'0ЕСТЬ0'в'377' , текст сообщения "ЕСТЬ"
кркч	конд	п'377737'   , константа для разборки слога
ОТЛТЕР	пам	1            , шкала отлож. обработки запросов
ШНЕРОТ	пам	1            , шкала необработанных работ
Д2047	КОНД В’20107’        , константа 20107₈
ПНО	конд	м24п' -↑'   , символ " -↑"
	пам	1
П7П7	КОНД М4В’7’В’7’    , маска 7 и 7 разрядов
	конд	в'4000000000000000' , константа E48
май77	конд	в'0000000060000000' , маска разрядов
О18П15	КОНД М14В’17’В’-1’ , маска 18-15 разрядов
	пам	1            , 44-е слово
вл	конд	в'6000000001000000' , константа "вл"
П11	КОНД В’11’          , константа 11₈ (тандем)
НАЧТЕК	экв	П11         , начало текста
П7	конд	в'7'        , константа 7₈

***************************************************
* ТОЧКА ВХОДА В НЕРЕЗИДЕНТ (ЕNТRУ).
* АКТИВИРУЕТСЯ ПО Е30 (БОНБОТ).
* СОХРАНЯЕТ ШКАЛУ РАБОТ, ЗАТЕМ ПЕРЕХОДИТ
* К ОБРАБОТКЕ ОЧЕРЕДНОЙ ЗАЯВКИ.
***************************************************
ЕNТRУ	УИА	1027        , блокировка прерываний
	пб	entry1       , переход к основной логике
шбнбо1	пам	1            , рабочая ячейка (переменная)
****************************
шпмвыд	пам	5            , рабочие ячейки для ПМВЫД (5 слов)
***************************
entry1	сч	ШКРАБН       , загрузить шкалу работ нерезидента
	зп	ШНЕРОТ       , сохранить в ШНЕРОТ
	сч	              , очистить СМ
	зп	ШКРАБН       , сбросить шкалу работ
КОНРАБ	сч	ОТЛТЕР       , проверить отложенные запросы
	по	СЛЕДР        , если нет → продолжить (СЛЕДР)
	зп	ШКРАБН(М1)  , сохранить текущую работу как отложенную
	сч	0             , очистить
	зп	ОТЛТЕР       , сбросить шкалу отложенных
	сч	ШКРАБН       , обновить шкалу работ
	или	E48(М1)      , установить бит для данной работы
	зп	ШКРАБН       , сохранить
СЛЕДР	НОП	.             , следующая работа
	уиа	'3'          , разрешить прерывания
	СЧ	ШНЕРОТ       , загрузить оставшиеся работы
	ПО	ВЫХОД        , если все выполнены → выход
	НЕД	П77777       , найти старший бит
	УИ	М1           , М1 := номер работы (1-48)
	СЧ	ШНЕРОТ       , сбросить бит в шкале
	НТЖ	Е48(М1)
	ЗП	ШНЕРОТ
	уиа	0(М15)       , М15 := 0 (признак для перекл.)
	мода	ПЕРЕКЛ-1     , адрес таблицы переходов
	мода	(М1)         , смещение по номеру работы
	пв	(М4)         , вызов обработчика работы (ПЕРЕКЛ)

***************************************************
* БЛОК ВЫХОДА ИЗ НЕРЕЗИДЕНТА.
* ГАСИТ БИТ "НЕТ ДИА" В ЯЧЕЙКЕ ЗАНЯТА,
* ВЫДАЁТ ПРЕДУПРЕЖДЕНИЕ О СБРОСЕ ЭВМ,
* ЗАТЕМ ЗАВЕРШАЕТ РАБОТУ.
***************************************************
ВЫХОД	НОП	,             , терминалы не прикрыли
	СЧ	ЗАНЯТА       , проверить флаг "НЕТ ДИА"
	И	Е44
	ПО	ВЫХ1         , если не было → ВЫХ1
	пам	0
	НТЖ	ЗАНЯТА       , сбросить бит E44 в ЗАНЯТА
	ЗП	ЗАНЯТА       , обновить
* ЗДЕСЬ ИСПОЛЬЗУЕТСЯ ОТСУТСТВИЕ ВНЕШНИХ ПРЕРЫВАНИЙ
* ПРИ ВЫПОЛНЕНИИ ПРАВОЙ КОМАНДЫ, ПОЭТОМУ БЛПР
* НЕ ТРЕБУЕТСЯ.
*** ВЫДАЧА ПРЕДУПРЕЖДЕНИЯ О СБРОСЕ ЭВМ ***
	сч	ШКУСТР       , прямые терминалы
	или	ШКАС         , добавить АС
	и	ШЗНКТ        , выделить операторские
	зп	РЯРОТ        , сохранить в РЯРОТ
	мода	g2            , адрес текста "КОНЧАЙТЕ"
	уиа	0(М16)
	мода	go            , адрес начала цикла
	уиа	0(М17)
go	сч	РЯРОТ        , загрузить шкалу терминалов
	по	ВЫХ1         , все обработаны → ВЫХ1
	нед	Е15П1        , найти старший бит
	уи	М2           , М2 := номер терминала
	сда	64-40        , сдвинуть для вставки
	или	УХОДИ        , добавить текст "КОНЧА"
	зп	(М16)        , записать в буфер выдачи
	сч	РЯРОТ        , сбросить бит в шкале
	нтж	E48(М2)
	зп	РЯРОТ

* ВЫДАЧА ТЕКСТА НА ЭКРАН ЧЕРЕЗ CONSUL
ВЫДАТЬ	НОП	             , вызов выдачи (метка "ОБРВЗ")
	УИА	3             , разрешить прерывания
	УИИ	М32(М17)      , сохранить адрес возврата
	СЧ	Е23           , загрузить код вызова CONSUL
	ПБ	ТВ40          , вызов нерезидента CONSUL
ВЫХ1	уиа	'2003'       , блокировка прерываний
	пв	ЗАНОСМ(М16)   , вызов ЗАНОСМ (отбраковка трактов)
	сч	E30           , загрузить код события
	пб	ОТКАЗН        , отказ от нерезидента

