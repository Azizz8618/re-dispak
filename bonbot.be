ЗАПРОС	СЧ	ТСЛ(М2)     , загрузить ТСЛ терминала
	И	ЕПРИМ        , проверить бит "Приём"
	ПЕ	КОМЛИН       , если да → коммутация линии
	СЧ	ТСЛ(М2)     , проверить служебную выдачу
	И       ЕСВД
	ПЕ	ОТЛРАБ       , идёт LF для отлож. запроса
	мода	ЗАПР1        , адрес возврата
	уиа	0(М16)
вокар1	сч	ТБЛ(М2)     , загрузить адрес рекорда
	зп	РЯ1          , сохранить в РЯ1
	сч	Е46Е45       , начальное значение счётчика
	мод	ТСЛ(М2)     , записать в ТСЛ
	зп
	сч	ТСЛ(М2)     , восстановить ТБЛ из ТСЛ
	зп	ТБЛ(М2)
	уи	М17          , М17 := адрес начального рекорда
	и	ЕТАВ         , проверить бит "Не возвращать каретку"
	пе	ЗАПР4        , если да → пропустить возврат
