        зп      Н+1(М16)     , очистить следующее слово
        СЧ      ТСЛ(М17)
        ИЛИ     ЕВRЕАК       , установить признак BREAK
        ИЛИ     ЕЗВОН        , и звонок
        ЗП      ТСЛ(М17)
        АПУ     (&К71).ДА6А
        АПБ     .НЕТ3А
.ДА6А   АНОП
        пб      ВЫХОД        , для К-71 – сразу выход
.НЕТ3А  АНОП
*
        АПУ     (&К71).ДА6   ; для К-71: обрыв связи
        УИИ     М16(М17)      ; М16 := номер терминала
        ПИО     ОБРЫВ(М13)   ; если прямой → ОБРЫВ
        СЛИА    ’64’(М16)    ; иначе добавить 64 для АС
ОБРЫВ   СЧИ     М16
        И       П37           ; выделить младшие 5 бит
        УИ      М15
        СЧИ     М16
        СДА     64+5          ; выделить номер группы
        УИ      М16
        СЧ      ШКТАС(М16)   ; шкала обрывов
        ИЛИ     Е48(М15)      ; отметить обрыв
        ЗП      ШКТАС(М16)
        ПБ      ВЫХОД
*
АС7     УИ      М17           ; восстановить лог. номер
        СЛИА    -1(М17)
        СЧ      ШКОПТТ        ; проверить, операторский ли
        И       Е48(М17)
        ПО      гашош         ; не операторский → ошибка
        ПВ      СБРОСБ(М14)   ; сброс буфера
        И       Е16           ; проверить тип терминала
        ПЕ      ВЫДNЦП        ; ВТ-340 → выдать номер БЭСМ
        ПБ      ас7в          ; ТТ → специальная обработка
.ДА6    АНОП
        АПУ     (&К71).ДА6Б
.ДА6Б   АНОП
*
АС5     сч      ШЗПРИМ        ; проверить, идёт ли приём
        и       E48(М17)
        пе      ВЫХОД         ; нет приёма → выход
        уиа     E29(М15)      ; признак ошибки приёма
АС4     сч      ТСЛ(М17)      ; записать признаки ошибки
        или     (М15)         ; в ТСЛ
        зп      ТСЛ(М17)
        пб      ВЫХОД
*
        АПУ     (&К71).ДА6В
АС9     СЧИ     М17           ; попытка спасти терминал
        СДА     64-8          ; сдвинуть физ. номер
        ИЛИ     Е15            ; добавить признак
        ЗП      ТАС            ; записать в ТАС(0)
        УИА     ВЫХОД(М15)    ; адрес возврата
        ПБ      уствд3        ; установить выдачу
АС76А   СЧ      R(М13)        ; анализ результата опроса
        НТЖ     ГОД            ; сравнить с N своей БЭСМ
        И       П7
        ПО      АС76В          ; совпадает → АС76В
        СЧ      R(М13)        ; не совпадает
        И       Е4            ; проверить переключение
        УИА     ВЫХОД(М15)
        ПЕ      ВЫКЛБ2        ; нельзя переключать → выход
        СЧ      ВППС(М17)     ; включить будильник на 10 с
        ИЛИ     Е46
        ЗП      ВППС(М17)
        ПБ      ВЫХОД
АС76В   СЧ      ШКОЛА         ; сбросить опрос линии
        НТЖ     Е48(М17)
        ЗП      ШКОЛА
        УИА     УСТВД2(М15)   ; начать выдачу
ВЫКЛБ2  СЧ                     ; выключить будильник
        ЗП      ВППС(М17)
        УИА     ВЫХОД(М16)
        ПБ      (М15)         ; перейти по адресу в М15
КЧС     СЧ      ШКОРАБ        ; *** ПРЕКРАЩАЕМ РАБОТУ С АС ***
        ИЛИ     Е44           ; установить бит "Конец"
        ЗП      ШКОРАБ
        СЧ      ШКВЫД         ; сбросить выдачу для прямых
        И       ШКУСТР
        ЗП      ШКВЫД
        УИА     вас1(М16)     ; адрес входа обработчика АС
        СЧИ     М16
        ЗП      адраб         ; сохранить адрес
        УИА     ВЫХОД(М15)
        СЧ      Е7
        ПБ      ГАШПРП        ; гашение 7-го разряда ПРП
***************************************************
* БЛОК ВЫДАЧИ СИМВОЛОВ В АС (ПРЕРЫВАНИЯ 7Р. ПРП)
* ОТСУТСТВУЕТ В МОТТ-117А.
***************************************************
вас1    СЧ      0           , обнулить сумму
        ЗП      шксин       , сбросить шкалу синхронизации
        СЧ      ШКВЫД       , загрузить шкалу выдачи
        И       ШКАС        , выделить терминалы АС
        ПО      ГМВМПД      , если нет выдач в АС → завершить
        НТЖ     шксин       , сравнить с шкалой синхр. (0)
        И       ШКВЫД       , оставить только активные выдачи
        ПО      вас1        , остались только ТТ → повторить
        ЗП      ШСЕРАС      , сохранить как готовую серию
        ПАМ     0           , резервная ячейка
        СЧ      ТАС         , проверить ТАС(0) (аварийный)
        ПЕ      sos         , есть кого спасать → sos
        СЧ      ШСЕРАС      , загрузить шкалу серии
        НЕД                 , найти старший бит (лог. N)
        УИ      М15         , М15 := номер терминала
        ПИО     орс3(М15)   , если нет активных → орс3
        СЛИА    -1(М15)     , преобразовать в индекс шкалы
        СЧ      ШСЕРАС      , сбросить бит в шкале
        НТЖ     Е48(М15)    , инвертировать бит
        ЗП      ШСЕРАС      , обновить шкалу серии
        СЧ      ТСЛ(М15)    , загрузить ТСЛ терминала
        СДА     64-6        , выделить физ. номер линии
        СЧМР                , извлечь младшую часть
        ЗП      R1          , R1 := физ. номер линии
        СЧ      ШКОЛА       , проверить шкалу опроса
        И       Е48(М15)
        ПЕ      ОПРОС       , был опрос → перейти к опросу
        СЧ      шас01       , проверить флаг выдачи "01"
        И       Е48(М15)
        ПО      ПРОВЫД      , "01" не нужна → к выдаче
        СЧ      Е4          , установить 4-й разряд слога
        ЗП      R           , R := код операции "01"
        СЧ      шас01       , сбросить флаг
        НТЖ     Е48(М15)
        ЗП      шас01
        ПВ      ВАС3Б1(М16) , вызов формирования слога (М16<>0)
ПРОВЫД  МОД     ТБЛ(М15)    , адрес рекорда в М16
        УИА     0(М16)      , М16 := адрес рекорда
        МОД     (М16)       , М17 := абсолютный адрес слова
        МОДА    (М16)
        УИА     0(М17)
        СЧ      9(М17)      , загрузить очередной байт (Н)
        СДА     64-8        , сдвинуть для выделения
        ЗП      9(М17)      , обновить слово
        СЧМР                , выделенный байт в СМ
        ЗП      R           , сохранить в R
        ПЕ      ВАС3В       , если не нуль → выдача
        УИА     0(М16)      , иначе слово кончилось, М16:=0
        СЧ      ТСЛ(М15)    , проверить, освобождать ли линию
        И       Е34
        ПО      ВАС3Б1      , не надо → продолжить
        СЧ      Е15         , выдать код "00" (освобождение)
        ЗП      R
        ПБ      ВАС3Г       , перейти к выдаче слога
*
*** ОПРОС ЛИНИИ ***
*
ОПРОС   НТЖ     ШКВЫД       , сбросить бит выдачи для опроса
        ЗП      ШКВЫД
        СЧ      Е4          , установить 4-й и 7-й разряды
        ИЛИ     Е7
        ЗП      R           , код операции опроса
        УИА     -1(М16)     , М16 := -1 (признак опроса)
ВАС3Б1  МОД     R1          , загрузить физ. номер линии
        СЧ      ТАС         , из ТАС(0) формируется слог
        СДА     64-3
        СЧМР
        ИЛИ     R           , добавить код операции
        ИЛИ     Е15
        ЗП      R
        ПБ      ВАС3Г
ВАС3В   СЧ      9(М17)      , слово ещё не выдано?
        ПЕ      ВАС3Г       , да → продолжить
        СЧ      (М16)       , иначе увеличить счётчик слов
        СЛЦ     Е1
        ЗП      (М16)
        СЛЦ     Е15П1       , сравнить с длиной рекорда
        НТЖ     3(М16)
        И       П7777
        ПЕ      ВАС3Г       , рекорд не исчерпан → продолжить
        СЧИ     М15         , иначе завершить обработку
        СЛЦ     СВИСТ5
        ПБ      ПРЯТ
ВАС3С   СЧ      ТСЛ(М15)    , проверить служебную выдачу
        И       Е26
        ПЕ      ВАС3Г       , закончим только при "000"
        СЧ      1(М16)      , есть ли следующий рекорд?
        ПО      ВАС3Д       , нет → выдать "00"
        ЗП      ТБЛ(М15)    , иначе перейти к следующему
ВАС3Г   СЧ      R1          , выдача слога в АС
        СДА     64-8        , физ. номер в старшую часть
        ИЛИ     R
        УВВ     '143'       , команда выдачи в мультиплексор
        ПИНО    орс1(М16)   , если не "00" → орс1
        НТЖ     ГОД         , сравнить с номером своей БЭСМ
        И       П7
        УИА     SLINЕ1(М16) , для чужой БЭСМ → переключение
        ПЕ      КВ3
        ПВ      КОНВЫД(М16) , иначе завершить выдачу
*
*** БЛОК УПРАВЛЕНИЯ ВЫДАЧЕЙ ***
*
орс1    УИА     вас1+5(М16) , адрес возврата
        СЧ      ШКВИД       , проверить шкалу ВТ-340
        И       Е48(М15)
        ПЕ      орс2        , выдали на ВТ → орс2
        ЗП      темптт      , сбросить счётчик серий ТТ
        СЧ      шксин       , отметить синхронизацию
        ИЛИ     Е48(М15)
        ЗП      шксин
орс2    СЧ      ШСЕРАС      , серия не закончена?
        ПЕ      ЗАПВХО      , нет → продолжить
орс3    УИА     вас1+1(М16) , следующий вход
        СЧ      шксин       , были выдачи на ТТ?
        ПО      ЗАПВХО      , нет → продолжить
        СЧ      темптт      , увеличить счётчик серий ТТ
        СЛЦ     Е44
        ЗП      темптт
        ПЕ      ЗАПВХО      , рано выдавать ТТ
        УИА     вас1(М16)   , в след. серии будут и ТТ
******
ЗАПВХО  СЧИ     М16         , сохранить адрес следующего входа
        ЗП      адраб
*
.ДА6В   АНОП
ПРПРО2  сч      E37         , метка EXIT1: гашение 37 разр. ГРП
        нтж     ВСЕЕД       , инвертировать маску
        уи                  , в индекс
        рег     '37'        , гасить разряд ГРП
        пб      БМВ         , выход в диспетчер прерываний
*
        АПУ     (&К71).ДА6Г
******
ВАС3Д   СЧ      (М16)       , счётчик слов - 1 (для "00")
        СЛЦ     Е15П1
        ЗП      (М16)
        ПБ      ВАС3Г
ГМВМПД  СЧ      ТАС         , проверить ТАС(0)
        ПЕ      sos         , есть аварийный терминал
        УИА     вас1(М16)   , адрес возврата
        УИА     ЗАПВХО(М15)
        СЧ      Е6
        ПБ      ГАШПРП      , гасить 6-й разряд ПРП
***************************************************
* ПЕРЕКЛЮЧЕНИЕ ЛИНИИ НА ДРУГУЮ ЭВМ (SLINE1)
* ВЫЗЫВАЕТСЯ, КОГДА N БЭСМ В СЛОГЕ НЕ СОВПАДАЕТ
* С НАШИМ. ОСВОБОЖДАЕТ РЕСУРСЫ ТЕРМИНАЛА И,
* ЕСЛИ ОН ОПЕРАТОРСКИЙ, ЗАКРЕПЛЯЕТ ЛИНИЮ ЗА
* НАШЕЙ МАШИНОЙ.
***************************************************
SLINЕ1  СЧ      ШЗПРИМ      , загрузить шкалу запрета приёма
        ИЛИ     Е48(М15)    , установить бит терминала
        НТЖ     Е48(М15)    , сбросить бит (разрешить приём)
        ЗП      ШЗПРИМ      , обновить шкалу
        СЧ      ШКОПТТ      , проверить шкалу операторских
        И       Е48(М15)    , терминалов для этого номера
        УИА     ВХОД3В(М16) , адрес возврата = ВХОД3В
        ПЕ      ВАС76А      , если операторский → спецобработка
* НЕОПЕРАТОРСКИЙ ТЕРМИНАЛ: ОСВОБОДИТЬ РЕСУРСЫ
        СЧ      ШКАС        , шкала активных терминалов АС
        НТЖ     Е48(М15)    , сбросить бит терминала
        ЗП      ШКАС        , обновить шкалу
        СЧ      СЛОN        , список свободных лог. номеров
        ИЛИ     Е48(М15)    , вернуть лог. номер в список
        ЗП      СЛОN        , обновить список
        СЧ      ШКВИД       , шкала ВТ-340
        ИЛИ     Е48(М15)    , установить бит (зачем?)
        НТЖ     Е48(М15)    , сбросить бит (очистить)
        ЗП      ШКВИД       , обновить шкалу
ВАС76А  СЧ      ШКВЫД       , шкала выдачи
        НТЖ     Е48(М15)    , сбросить бит (завершить выдачу)
        ЗП      ШКВЫД       , обновить шкалу
        ПБ      ЗАПВХО      , сохранить адрес и выйти
* ОПЕРАТОРСКИЙ ТЕРМИНАЛ: ЗАКРЕПИТЬ ЛИНИЮ ЗА НАМИ
ВХОД3В  СЧ      R1          , физ. номер линии
        СДА     64-8        , сдвинуть в старшую часть
        ИЛИ     CTRLN        , добавить управляющий код CTRLN
        УВВ     '143'       , выдать команду мультиплексору
        СЧ      ГОД         , загрузить номер своей БЭСМ
        СДА     64+3        , сдвинуть для выделения бита
        СЧМР                , извлечь сдвинутое значение
        ЗП      R           , сохранить в R
        МОД     R1          , адресоваться по физ. номеру
        УИА     0(М16)      , М16 := индекс в ТАС
        СЧ      ШКОПТТ      , шкала операторских терминалов
        МОД     ТАС(М16)    , маска по текущей ТАС
        И       Е48-1       , выделить бит терминала
        УИА     Е18П16(М15) , маска для неоператорского
        ПО      ВАС76D       , если бит не установлен → ВАС76D
        УИА     Е18П1(М15)  , маска для операторского
ВАС76D  СЧ      ТАС(М16)    , загрузить запись ТАС
        И       (М15)       , очистить поле N БЭСМ (маска)
        ИЛИ     R           , вставить номер нашей БЭСМ
        ЗП      ТАС(М16)    , обновить ТАС
        УИА     вас1+1(М16) , начать серию выдачи заново
        ПБ      ЗАПВХО      , сохранить адрес и выйти
*
*** ОСВОБОЖДЕНИЕ (РНМ :=0) СЛУЧАЙНОГО ТЕРМИНАЛА ***
*
sos     УВВ     '143'       , команда сброса линии в АС
        СЧ                  , очистить сумматор
        ЗП      ТАС         , обнулить ТАС(0) (аварийный)
        ПБ      ПРПРО2      , выход из прерывания
*
.ДА6Г АНОП
***************************************************
* БЛОК ЗАВЕРШЕНИЯ ВЫДАЧИ (КОНВЫД)
* ВХОД: М15 – ЛОГ. НОМЕР ТЕРМИНАЛА.
* ГАСИТ ШКВЫД, ВОССТАНАВЛИВАЕТ ТБЛ И СЧЁТЧИКИ,
* ПРИ НЕОБХОДИМОСТИ УСТАНАВЛИВАЕТ ШКОКВД И
* ЗАПУСКАЕТ ОБРАБОТКУ КОНЦА ВЫДАЧИ.
***************************************************
КОНВЫД  СЧ      ШКВЫД       , загрузить шкалу выдачи
        НТЖ     Е48(М15)    , сбросить бит терминала
        ЗП      ШКВЫД       , обновить шкалу (выдача завершена)
        СЧ      ТСЛ(М15)    , загрузить ТСЛ терминала
        И       ЕСВД        , проверить бит "Служебная выдача"
        ПЕ      КВ2         , если да → спец. завершение (КВ2)
        сч      ш31         , проверить флаг запрета приёма
        пе      КВ2         , если установлен → КВ2
        СЧ      ШЗПРИМ      , снять запрет приёма
        ИЛИ     Е48(М15)    , установить бит
        НТЖ     Е48(М15)    , сбросить бит
        ЗП      ШЗПРИМ      , обновить шкалу (приём разрешён)
        сч      ТСЛ(М15)    , проверить бит "Подзапуск" (Е32)
        и       E32
        по      КВ2         , если нет → КВ2
        мод     ТБЛ(М15)    , адрес рекорда
        сч      5           , загрузить сохранённый счётчик (ДЛИНА)
        мод     ТБЛ(М15)    , и записать его в начало рекорда
        зп                  , восстановить счётчик
        пб      КВ4         , продолжить
КВ2     СЧ      Е46Е45      , начальное значение счётчика (0)
        МОД     ТСЛ(М15)    , записать в ТСЛ (счётчик символов)
        ЗП
        СЧ      ТСЛ(М15)    , восстановить ТБЛ из ТСЛ
        ЗП      ТБЛ(М15)    , (адрес начала рекорда)
        И       ЕПРИГ       , проверить бит "Приглашение"
        ПЕ      КВ4         , если было приглашение → КВ4
КВ3     СЧ      ШКОКВД      , шкала окончания выдачи
        ИЛИ     Е48(М15)    , отметить терминал
        ЗП      ШКОКВД      , обновить шкалу
        СЧ      ШКОРАБ      , шкала работ
        ИЛИ     ЕВЫД        , установить бит "Выдача"
        ЗП      ШКОРАБ      , обновить шкалу работ
КВ4     СЧИ     М15         , номер терминала в СМ
        СЛЦ     СВИСТ7      , добавить смещение для обработчика
        ПБ      ПРЯТ        , переход к ПРЯТ (завершение прерывания)
КВ4А    СЧ      ТСЛ(М15)    , очистить флаги в ТСЛ
        И       ГАШТСЛ      , маской ГАШТСЛ
        ЗП      ТСЛ(М15)    , обновить ТСЛ
        и       E17         , проверить бит АС (17)
        ПБ      (М16)       , возврат

***************************************************
* БЛОК ПРИЕМА ПО ТЕЛЕГРАФНЫМ КАНАЛАМ (ottvt)
* ВЫЗЫВАЕТСЯ ПО 40-МУ РАЗРЯДУ ГРП (ТАЙМЕР).
* ОПРАШИВАЕТ ТЕЛЕГРАФНЫЕ КАНАЛЫ, НАКАПЛИВАЕТ
* БИТЫ ПРИНИМАЕМЫХ СИМВОЛОВ.
***************************************************
ottvt   сч      СЧПР1       , счётчик прерываний
        слц     E1          , увеличить на 1
        зп      СЧПР1       , обновить счётчик
        уи      М15         , сохранить в М15
        уии     М16(М15)    , копия в М16
        слиа    -3(М15)     , вычесть 3
        и       E3          , проверить кратность 3
        пе      уим15       , если не кратен → уим15
        слиа    5(М15)      , иначе добавить 5 (сдвиг для опроса)
уим15   сч      тпп         , маска опроса телетайпов
        нтж     тппv        , инвертировать по маске ВТ
        зп      АКТИВН      , сохранить как активные линии
        увв     '4100'      , опрос терм. каналов (tty_query)
        сда     64-36       , сдвинуть результат вправо
        и       АКТИВН      , выделить активные линии
        зп      символ      , сохранить принятые биты
        нтж     АКТИВН      , инвертировать
        или     шкуст1      , добавить ранее активные
        зп      шкуст1      , обновить шкалу под током
        нтж     РАБШК       , сравнить с рабочей шкалой
        или     ШЗПРИМ      , добавить запрет приёма
        нтж     ШЗПРИМ      , убрать запрет
        и       символ      , выделить изменения
        зп      Р1          , сохранить в Р1
        или     РАБШК       , добавить к рабочей шкале
        зп      РАБШК       , обновить рабочую шкалу
        сч      Р1          , загрузить изменения
        или     РАБШК(М15)  , добавить в группу
        зп      РАБШК(М15)  , обновить групповую шкалу
        сч      РАБШК(М16)  , загрузить общую шкалу

***************************************************
* ВЫДЕЛЕНИЕ ПРИНЯТОГО СИМВОЛА (пр1)
* ОБРАБАТЫВАЕТ НАКОПЛЕННЫЕ БИТЫ, ФОРМИРУЕТ
* ПОЛНЫЙ СИМВОЛ В ГТСЛ+8.
***************************************************
пр1     зп      Р           , сохранить рабочую шкалу
        по      пр3         , если все биты приняты → пр3
        нед     Е15П1       , найти старший бит
        уи      М15         , М15 := номер терминала
        уиа     (М17)       , М17 := 0 (по умолчанию)
        пино    пр3б(М16)   , если не ВТ → пр3б
        уиа     3(М17)      , для ВТ: М17 := 3 (сдвиг)
пр3б    сч      символ      , загрузить принятые биты
        и       E48(М15)    , выделить бит терминала
        сда     64+7(М17)   , сдвинуть вправо (для ВТ на 3)
        или     симво1(М15) , добавить к накопленному полубайту
        сда     64-1        , сдвинуть влево на 1
        зп      симво1(М15) , обновить накопленный байт
        и       E48(М15)    , проверить, завершён ли символ
        по      пр2         , если нет → пр2
        пио     пр2а(М16)   , если от ВТ (19Р ГРП) → пр2а
        нтж     РАБШК(М16)  , сбросить бит в рабочей шкале
        зп      РАБШК(М16)
пр2а    сч      естьс       , установить флаг "есть символ"
        или     E48(М15)
        зп      естьс
        сч      симво1(М15) , загрузить готовый символ
        зп      ГТСЛ+8(М15) , сохранить в ГТСЛ+8 (буфер приёма)
        сч                  , очистить накопленный байт
        зп      симво1(М15)
        сч      РАБШК       , обновить рабочую шкалу
        нтж     E48(М15)    , сбросить бит
        зп      РАБШК
пр2     сч      Р           , загрузить оставшуюся шкалу
        нтж     E48(М15)    , сбросить обработанный бит
        пб      пр1         , продолжить цикл
пр3     сч      символ      , загрузить итоговые биты
        и       ШКУСТР      , выделить прямые терминалы

* БЛОК ФИЛЬТРАЦИИ ДЛЯ К-71
        АПУ     (&К71).ДА6Д
		АПБ	.ОБЩ6Д
*
.ДА6Д АНОП
		или     шзпри7      , добавить шкалу запрета приёма К-71
        нтж     шзпри7      , сбросить её
.ОБЩ6Д  АНОП
        или     ШКВЫД       , добавить шкалу выдачи
        нтж     ШКВЫД       , сбросить шкалу выдачи

        АПУ     (&К71).ДА6Е
        или     ШЗПРИМ      , добавить шкалу запрета приёма
        нтж     ШЗПРИМ      , сбросить её
.ДА6Е   АНОП
        и       ТАЙНА       , применить маску дуплексных линий
        или     Р1          , добавить изменения
        нтж     ВКАНАЛ      , сравнить с предыдущим значением
        и       АКТИВН      , оставить только активные линии
        нтж     ВКАНАЛ      , выделить изменившиеся биты
        зп      ВКАНАЛ      , обновить канал выдачи

* ВЫБОР ДАЛЬНЕЙШЕГО ДЕЙСТВИЯ ПО ТИПУ ТЕРМИНАЛА
        АПУ     (&К71).ДА7
пр3а    пио     пр4(М16)    , если не ВТ → пр4
        АПБ     .НЕТ5
.ДА7    АНОП
пр3а    пио     vt19бк(М16) , для К-71: переход к обработке ВТ
.НЕТ5   АНОП
        уии     М15(М16)    , М15 := М16 (тип?)
        слиа    -5(М15)     , вычесть 5

        АПУ     (&К71).ДА7А
        пио     вд(М15)     , если 0 → выдача в каналы
        АПБ     .НЕТ5А
.ДА7А   АНОП
        пино    пр3к71(М15) , для К-71: приформировать выдачу
.НЕТ5А  АНОП

* БЛОК ВЫДАЧИ В ТЕЛЕГРАФНЫЕ КАНАЛЫ (ШТАТНЫЙ)
        АПУ     (&К71).ДА8
влинии  сч      вкан        , биты выдачи в телеграфные линии
        или     ВКАНАЛ      , добавить новые
        увв     '140'       , выдать в каналы (tty_send)
        пб      пр4
пр4     сч      ШКВИД       , загрузить шкалу ВТ-340
        пб      vt19б       , переход к обработке ВТ
        сч      ГУС         , загрузить ГУС
        пб      врзад       , суммирование времени по задаче
        пб      нпрмб       , переход к "гори"
        мода
        пб      нпрмб

        АПБ     .НЕТ6
.ДА8    АНОП

***** БЛОК N2 ДЛЯ РАБ. С АППАРАТУРОЙ К-71 *****
        сч                  , очистить СМ
        зп      СЧПР1       , сбросить счётчик прерываний
вдк71   уиа     4(М16)      , М16 := 4 (число каналов?)
        сч      тслк71(М15) , загрузить шкалу каналов К-71
        по      влинк7(М15) , если пусто → влинк7
        мод     тблк71(М15) , адрес таблицы
        уиа     (М17)       , М17 := 0
        мода    (М15)
        сч      счоптр+1(М17) , загрузить счётчик опроса
        нтж     ВЫДАТЬ      , сравнить с текущей выдачей
        и       тслк71(М15) , выделить активные
        нтж     ВЫДАТЬ      , обновить выдачу
        зп      ВЫДАТЬ      , сохранить
        цикл    вд2к71(М17) , цикл по каналам
        сч      тслк71(М15) , загрузить шкалу
        нтж     факел       , сбросить активные линии
        зп      факел
        сч                  , очистить
        зп      тслк71(М15) , сбросить шкалу каналов
        пб      пр3к71      , переход к выдаче

влинк7  сч      тпп         , загрузить маску ТТ
        мода    4
вд1к71  уиа     -10(М17)    , М17 := -10 (счётчик?)
        нтж     тппv        , инвертировать по ВТ
        и       факел       , выделить активные линии
        зп      тслк71(М15) , сохранить шкалу каналов
вд2к71  счи     М17         , загрузить счётчик
        зп      тблк71(М15) , сохранить в таблице
пр3к71  сч      ВКАНАЛ      , биты выдачи в телеграфные линии
        или     ВЫДАТЬ      , добавить выдачу
        сда     64+24       , сдвинуть вправо на 24
        уи                  , в индекс
        увв     '140'       , выдать в телеграфные каналы
        сч      ШКВЫД       , загрузить шкалу выдачи
        или     шзпри7      , добавить запрет приёма К-71
        нтж     шзпри7      , убрать его
        и       Е48П25      , маска 48-25
        нтж     факел       , сравнить с активными линиями
        или     естьс       , добавить флаг "есть символ"
        и       шкуст1      , выделить прямые терминалы
        по      пр4к71(М16) , если 0 → пр4к71
        сч      E6          , иначе установить 6-й разряд
пр4к71  увв     '31'        , имитация прерывания ГРП
* Имитация прерывания по 6Р. ПРП
        пб      пр4к71(М16) , зацикливание для ожидания
        сч      ГУС         , загрузить ГУС
        пб      врзад       , суммирование времени
пр4к7а  пб      нпрмб       , заглушка
пр4к7б  пб      нпрмб       , заглушка
вбоэхл  пб      маска       , переход в БОЭК1 (маска)

.НЕТ6   АНОП
        АПУ     (&К71).ДА9

***** БЛОК ВЫДАЧИ В ТЕЛЕГРАФНЫЕ КАНАЛЫ ШТАТНЫЙ *****
вд      сч                  , очистить СМ
        зп      СЧПР1       , сбросить счётчик прерываний
        сда     64+24       , сдвинуть (зачем? видимо, часть алгоритма)
        и       вкан         , выделить активные каналы
        зп      вкан         , обновить текущую выдачу
        и       ШКУСТР       , выделить прямые терминалы
        или     ШКВИД        , добавить ВТ-340
        нтж     ШКВИД        , оставить только изменения
вд1     зп      Р            , сохранить в Р
        уиа     4(М16)       , адрес выхода
        по      влинии       , если нет активных → влинии
        нед     Е15П1        , найти старший бит
        уи      М15          , М15 := номер канала
        сч      ТСЛ(М15)     , загрузить ТСЛ
        и       Е17          , проверить АС
        пе      вд2а         , если консул → вд2а
        мод     ТБЛ(М15)     , адрес рекорда
        уиа     (М16)        , М16 := адрес рекорда
        мод     4(М16)       , М17 := номер разряда на выдачу
        уиа     (М17)
        сч      Н(М16)       , загрузить слово рекорда
        мода    (М16)
        сда     64-24(М17)   , сдвинуть для выделения бита
        и       Е24(М15)     , маска для данного терминала
        или     вкан          , добавить к выдаче
        зп      вкан          , обновить канал выдачи
        слиа    -1(М17)       , следующий разряд
        пино    вд2(М17)      , если не все → вд2
        сч      (М16)         , увеличить счётчик слов
        слц     Е1
        зп      (М16)
        уиа     48(М17)       , номсим := 48
        сч      ТСЛ(М15)      , проверить служебную выдачу
        и       ЕСЛВ
        пе      вд2г          , закончить только при 0
        сч      (М16)         , проверить длину рекорда
        слц     Е15П1
        нтж     ДЛ(М16)
        и       Е15П1
        по      вд2в          , рекорд исчерпан
вд2г    мод     (М16)         , загрузить слово рекорда
        сч      Н(М16)
        по      вд2б          , если 0 → конец выдачи
        пб      вд2           , продолжить
вд2в    сч      ВН            , ссылка на следующий рекорд
        по      вд2б          , если нет → конец
        зп      ТБЛ           , обновить ТБЛ
        счи     ПРЯТ          , адрес обработчика ПРЯТ
        слц     СВИСТ6        , добавить смещение
        пб      ПРЯТ          , перейти к ПРЯТ
вд2вс   сч      ВН(М16)       , загрузить ссылку
        уи      М16           , обновить М16
вд2     счи     М17           , подправка номсим
        зп      4(М16)        , сохранить в рекорд
вд2а    уиа     вд1(М17)      , адрес возврата
        пб      пр2           , переход к обработке символа
вд2б    уиа     вд2а(М16)     , адрес возврата
        пб      КОНВЫД        , завершить выдачу

*
.ДА9	АНОП
***************************************************
* ПРИЕМ С ВТ ПО 19Р ГРП (vt19)
* ФИКСИРУЕТ НОВЫЕ ВТ-340 ПОД ТОКОМ, ОБНОВЛЯЕТ
* РАБОЧУЮ ШКАЛУ И ПЕРЕХОДИТ К ОБРАБОТКЕ БИТ.
***************************************************
vt19    сда     64-36       , выделить состояние ВТ (19-й разряд)
        и       тппv        , наложить маску разрешённых ВТ
        зп      символ      , сохранить принятые биты
        нтж     тппv        , инвертировать
        или     шквид1      , добавить ранее активные ВТ
        зп      шквид1      , обновить шкалу под током
        или     шкуст1      , добавить прямые ТТ под током
        зп      шкуст1      , обновить общую шкалу
        нтж     РАБШК       , сравнить с рабочей шкалой
        или     ШЗПРИМ      , добавить запрет приёма
        нтж     ШЗПРИМ      , убрать запрет
        и       символ      , выделить изменения
        зп      Р1          , сохранить в Р1
        или     РАБШК       , добавить к рабочей шкале
        и       шкуст1      , оставить только под током
        зп      РАБШК       , обновить рабочую шкалу
        сч      тппv        , загрузить маску ВТ
        зп      АКТИВН      , сохранить как активные линии
        сч      РАБШК       , загрузить рабочую шкалу
        и       шквид1      , оставить только ВТ-340
        уиа     (М16)       , М16 := 0 (признак ВТ)
        пе      пр1         , перейти к выделению символов

***************************************************
* ПРОДОЛЖЕНИЕ ДЛЯ ШТАТНОГО РЕЖИМА (vt19б)
* ОБРАБОТКА ВЫДАЧИ В ТЕЛЕГРАФНЫЕ КАНАЛЫ.
***************************************************
        АПУ     (&К71).ДА10
vt19б   и       ШКВЫД       , проверить шкалу выдачи
        и       ШКУСТР      , выделить прямые терминалы
        сда     64+24       , сдвинуть для выделения
        и       вкан         , выделить активные каналы
        нтж     вкан         , сбросить их
        зп      вкан         , обновить канал выдачи
        сч      МГРП        , загрузить маску ГРП
        или     Е19         , установить 19-й разряд
        зп      МГРП        , обновить маску
        сч      Р           , загрузить сохранённое значение
        пб      вд1         , перейти к выдаче в линии

.ДА10   АНОП
***************************************************
* БЛОК К-71 ДЛЯ РАБОТЫ С ТЕЛЕГРАФНЫМИ КАНАЛАМИ
* (vt19бк). ВКЛЮЧАЕТ 19-Й РАЗРЯД ГРП И ПЕРЕХОДИТ
* К ЛОКАЛЬНОМУ ОБРАБОТЧИКУ вдк71.
***************************************************
vt19бк  сч      МГРП        , загрузить маску ГРП
        или     E19         , установить 19-й разряд
        зп      МГРП        , обновить маску
        уиа     1(М15)      , М15 := 1 (признак для вдк71)
        пб      вдк71       , переход к локальной обработке

***************************************************
* ПРОДОЛЖЕНИЕ БЛОКА ОБРАБОТКИ ПРЕРЫВАНИЯ
* ПО ВЫДАЧЕ ОТ КОНСУЛА (выд4). ВЫДАЧА СЛЕДУЮЩЕЙ
* ЯЧЕЙКИ РЕКОРДА. ЕСЛИ РЕКОРД ИСЧЕРПАН –
* ПЕРЕХОД К СЛЕДУЮЩЕМУ ИЛИ ЗАВЕРШЕНИЕ.
***************************************************
выд4    сч      (М16)       , загрузить счётчик выданных слов
        слц     E1          , увеличить на 1
        зп      (М16)       , обновить счётчик
        слиа    1(М17)      , увеличить адрес (М17)
        слц     Е15П1       , добавить -1 (проверка границы)
        нтж     3(М16)      , сравнить с длиной рекорда
        и       Е15П1
        пе      выд4а       , если не равен → выд4а (продолжить)
        сч      1(М16)      , загрузить ссылку на следующий
        по      выд4б       , если нет → выд4б (конец)
        зп      ТБЛ+24(М15) , обновить ТБЛ (адрес рекорда)
        уи      М17         , М17 := адрес начала
        счи     М15         , номер терминала
        слц     СВИСТ8      , добавить смещение
        пб      ПРЯТ        , перейти к обработке
выд4а   сч      9(М17)      , загрузить очередной байт (Н)
        пе      вдсn3       , если не 0 → выдача символа
выд4б   уиа     БМВ(М16)    , выдали всё: адрес возврата
        слиа    24(М15)     , смещение для будильника
        зп      ВППС(М15)   , гашение будильника
        пб      КОНВЫД      , завершить выдачу
выд4в   сч                  , очистить СМ
        пб      вдсn1       , переход к выдаче символа (БОЭК1)

ЭКО     КОНД    (2)В'0'     , экстракод обмена (2 слова)
П175    конд    в'175'      , константа 175₈
        пам     2           , резерв
ПЕОТ    КОНД    В'207'      , константа 207₈
КЗП2    КОНД    М44В'13'    , конец приёма 2
