ВХБ1    нед                 , найти старший бит в шкале
        уи      М17         , М17 = номер направления
        сч      E40         , установить флаг задержки обмена
        или     ШЗПОМБ
        зп      ШЗПОМБ
        сч      ШКМБ(М16)   , снять бит занятости
        нтж     E48-1(М17)
        зп      ШКМБ(М16)
        уии     М5(М17)     , сохранить номер в М5
        пино    ВХБП(М16)   , если М16≠0 → обход для польз.
ВХБ2    сч      ТУС-1(М5)   , загрузить ГУС задачи
        уи      М15         , М15 = адрес ИПЗ задачи
        зп      ИПОБМ+9     , сохранить в 9-м слове ИПЗ обмена
        сч      СЧЗКМБ      , счётчик заказов к МБ
        слц     МИН15       , сравнить с минимумом
        пе      РАЗРЕ       , если не исчерпан → разрешить
        сч      ТУС-1(М5)   , иначе проверить тип задачи
        сда     64+41
        нтж     П12         , сравнить с 12
        по      СИСВХ       , равно → системный вход
        нтж     E1          , сравнить с 13
        по      СИСВХ
        нтж     П17         , сравнить с 17
        нтж     E2
        по      СИСВХ
        сч      ШКОМБ(М16)  , шкала отложенных обменов МБ
        или     E48-1(М17)  , отметить задачу
        зп      ШКОМБ(М16)
        пб      ДИСПМБ      , перейти к диспетчеру МБ

ВХБП    слиа    64(М5)      , М5 = М5 + 64 (следующая задача)
        пб      ВХБ2        , продолжить обработку

***************************************************
* СИСВХ – СИСТЕМНЫЙ ВХОД (ЗАКАЗ ОТ ФИЗОБМ ИЛИ ТБУФ)
* ФОРМИРОВАНИЕ РМР И ВЫЗОВ физо5.
***************************************************
СИСВХ   сч      шфзобм      , шкала ожидания физического обмена
        и       E48-1(М17)  , проверить, ждёт ли задача
        по      сисфзо      , если 0 → вход от ФИЗОБМ
        сч      2(М15)      , иначе загрузить 2-е слово ИПЗ (РМР)
сисфзо  зп      РМР         , сохранить адрес буфера
        сч      (М15)       , загрузить 1-е слово ИПЗ (СМ)
        пб      физо5       , перейти к формированию КУС МБ

***************************************************
* РАЗРЕ – РАЗРЕШЕНИЕ ОБМЕНА (СЧЁТЧИК НЕ ИСЧЕРПАН)
* ЗАГРУЗКА ИНФОРМАЦИОННОГО СЛОВА МБ.
***************************************************
РАЗРЕ   пио     СИСВХ(М16)  , если М16=0 → СИСВХ
        уиа     1(М17)      , М17 = 1 (режим?)
        сч      (М15)       , загрузить 1-е слово ИПЗ (СМ)
        зп      ИНФМБ       , сохранить как инф. слово МБ
        и       Е36         , проверить бит 36 (начало чтения?)
        пе      НАЧАЧУ      , если 1 → НАЧАЧУ
        пб      НАМБ        , иначе → НАМБ

***************************************************
* ФТН – ПРОВЕРКА ВОЗМОЖНОСТИ ОТКАЧКИ ЛИСТА:
* ЕСЛИ НА ЛИСТ НАЗНАЧЕН ВЫВОД НА АЦПУ, ОТКАЧКА
* ЗАПРЕЩЕНА. 32-Е СЛОВО ИПЗ – ЧИСЛО СТРОК АЦПУ
* В ОБРАТНОМ КОДЕ. 22-Е СЛОВО – М34 И КОПИЯ РЗ.
***************************************************
ФТН     уиа     ДИСПМБ(М1)  , адрес возврата = ДИСПМБ
        сч      УСММБ       , условное слово МБ
        сда     64+41       , выделить номер задачи
        уи      М17
        сч      ИНФМБ       , информационное слово МБ
        уиа     32(М16)     , М16 = 32 (код операции?)
ВЫ      сда     64+30       , выделить номер листа
        и       П37
        нтж     П37
        уи      М5          , М5 = номер листа (0–37)
        сч      (М15)       , проверить 0-е слово ИПЗ (СМ),
* если обмен не начат → обход
        по      ВЫХОТВ      , если 0 → чтение тракта прежде
* записи
        счи     М16         , сохранить код
        зп      8(М15)      , записать в 8-е слово ИПЗ (М18)
        уиа     ЗАПЭКС(М16) , адрес обработчика ошибки
        счи     М16
        уиа     '2003'      , блокировка прерываний с защитой
        пв      АВ(М16)     , вызвать аварийную остановку
ВЫХОТВ  сч      32(М15)     , 32-е слово ИПЗ – число строк
* АЦПУ в обратном коде
        нтж     22(М15)     , 22-е слово ИПЗ – М34 и копия РЗ
        и       E48(М5)     , маска проверяемого листа
        по      обх         , если лист не занят под АЦПУ –
* обход (разрешить откачку)
        нтж     32(М15)     , иначе сбросить признак вывода
* на АЦПУ (освободить лист)
        зп      32(М15)     , обновить 32-е слово ИПЗ
обх     сч      2(М17)      , загрузить 2-е слово ИПЗ (РМР)
        пв      ВШГП(М15)   , активировать пользовательскую
* задачу
        пб      (М1)        , возврат
