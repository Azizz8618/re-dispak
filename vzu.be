	нтж	КЛЮЧРЗ      , сравнить с ключом разметки
	пе	нетест      , не совпал – обычный вызов
	уиа	'2000'      , блокировка прерываний, запрет
* приписки
	сч	32          , 32-е слово (адрес для разметки?)
	уиа	'2003'      , блокировка прерываний с защитой
	сч	,           , очистить СМ
	пб	блразм      , перейти к блоку разметки
нетест	счи	М16         , сохранить код операции
	зп	И16
	мод	ГУС         , 1 группа задачи
	сч	E43
	сда	64+5
	мод	ГУС         , взять 33-е слово ИПЗ
	или	33
	и	Е17Е13      , признак реакции на экстракод
	по	продли      , если 0 – нет ожидающих событий
