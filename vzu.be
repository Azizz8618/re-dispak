* ЛШ - ХЛАМ, БОЭК1, НОМБОБ - ДЛЯ 64 К
* МАКРОПЕРЕМЕННЫЕ BS, МЫ НИП, G, GL, C, H ДЛЯ СВС МЕНЯЮТ ЗНАЧ.
* ЛГП УСТВ 0 ВМЕСТО G, GL - ТЕПЕРЬ НАДО "1"
*
*BS, G, GL, МЫ, УЧЕТ, ЭФ = 0
*ГП = Х
ВЗУ	СТАРТ	'5176'
	М
        E
*
	ГБЛВ ∧К71,∧ОТЛ,∧ГРАФ
∧К71 УСТВ 1
∧ГРАФ УСТВ 0


*
***************************************************
* ФИЗОБМ – ТОЧКА ВХОДА ФИЗИЧЕСКОГО ОБМЕНА (МБ/МЛ/МД)
* СОХРАНЯЕТ СМ В И20, ФОРМИРУЕТ КУС И ПЕРЕДАЁТ УПРАВЛЕНИЕ ФИЗО
***************************************************
ФИЗОБМ	уиа	'2003'        , блокировка прерываний
	зп	И20           , сохранить аргумент (КУС) в И20
ФИЗИЧ	зп	СМ            , сохранить КУС в СМ
	мод	НЗАД          , взять номер текущей задачи
	сч	E48-1         , сформировать маску задачи
	нтж	ВСЕЕД         , инвертировать маску
	и	шфзобм        , выделить флаг ожидания этой задачи
	зп	шфзобм        , снять флаг (задача больше не ждёт обмен)
	пб	ФИЗО          , перейти к общему обработчику

***************************************************
* ФИЗУР – ВХОД ДЛЯ ВНЕШНЕГО ЗАПРОСА (УР–УСТРОЙСТВО РАЗМЕТКИ?)
* УСТАНАВЛИВАЕТ ФЛАГ ОЖИДАНИЯ ОБМЕНА ДЛЯ ТЕКУЩЕЙ ЗАДАЧИ
***************************************************
ФИЗУР	зп	И20           , сохранить аргумент в И20
	зп	СМ            , сохранить КУС в СМ
	мод	НЗАД          , номер задачи
	сч	E48-1         , маска задачи
	или	шфзобм        , установить флаг ожидания
	зп	шфзобм        , сохранить в шкале ожидания обмена
***************************************************
* ФИЗО – ОБЩИЙ ДИСПЕТЧЕР ФИЗИЧЕСКОГО ОБМЕНА
* АНАЛИЗИРУЕТ КУС И ПЕРЕДАЁТ УПРАВЛЕНИЕ НА ФИЗОБД (ДИСКИ)
* ИЛИ ФИЗМБ (МБ) / ВХМЛЕ (МЛ)
***************************************************
ФИЗО	счрж	'37'          , сохранить РАУ
	зп	РК            , в ячейку РК
	уии	М33(М16)      , М33 = адрес возврата (из М16)
	сч	ИВ25          , взять конфигурацию прерывания
	уи	М27           , установить М27 (ССП)
	уиа	(М16)         , обнулить М16
	сч	ГУС           , ГУС текущей задачи
	и	Е48П42        , выделить номер задачи (42-48 разряды)
	сда	64-1          , сдвинуть в младшие разряды
	или	СМ            , добавить к КУС
	зп	СМ            , обновлённый КУС с номером задачи
	и	E39           , проверить 39-й разряд (признак дисков?)
	пе	ФИЗОБД        , если установлен → обмен с МД
	сч	СМ
	слц	E40           , проверить 40-й разряд
	и	E42           , и 42-й
	по	физмб         , если оба 0 → обмен с МБ
	сч	НЗАД
	нтж	П27           , сравнить номер задачи с 27₈
	по	ВХМЛЕ         , если задача 27 → обмен с МЛ
	сч	СМ
	и	E38           , проверить 38-й разряд (признак МЛ?)
	по	физмб         , если 0 → обмен с МБ
	пб	ВХМЛЕ         , иначе → обмен с МЛ
***************************************************
* анво9а – УСТАНОВКА ШКАЛЫ ЗАДЕРЖКИ ОБМЕНА
* (ВЫЗЫВАЕТСЯ ПРИ НЕВОЗМОЖНОСТИ НЕМЕДЛЕННОГО ОБМЕНА)
***************************************************
анво9а	сч	ШЗЗПСЧ        , шкала задержек обмена по чтению
	или	E48-1(М16)    , установить бит текущей задачи
	зп	ШЗЗПСЧ        , сохранить шкалу
	пб	АНВО9Б        , перейти к общей обработке задержки

***************************************************
* ФИЗЗП – ФИЗИЧЕСКАЯ ЗАПИСЬ (ИНВЕРТИРУЕТ БИТ 18 И ВЫЗЫВАЕТ ФИЗОБМ)
***************************************************
ФИЗЗП	нтж	E18           , инвертировать 18-й разряд (чтение/запись)
	пб	ФИЗОБМ        , перейти к ФИЗОБМ

***************************************************
* физмб – ПРОВЕРКА ДОСТУПНОСТИ МБ ДЛЯ ОБМЕНА
* ЕСЛИ НЕТ МБ – ВЫЗЫВАЕТ УКАЧКУ
***************************************************
физмб	сч	НЗАД          , номер текущей задачи
	нтж	П13           , сравнить с 13₈
	пе	ФМБ           , если не 13 → ФМБ
	сч	ТМБ           , проверить таймер МБ
	сда	64+3          , выделить старшие биты
	пе	ФМБ           , если не истёк → ФМБ
	уиа	48(М16)       , код ошибки 48 (нет МБ)
	пб	ЗПУК          , перейти к установке УКАЧКИ

***************************************************
* ВХМЛЕ – ПРОВЕРКА 24-ГО РАЗРЯДА КУСА
* ЕСЛИ УСТАНОВЛЕН → ОБМЕН С МД (ДЕ)
***************************************************
ВХМЛЕ	сч	СМ            , проверить 24-й разряд КУС
	и	E24
	пе	ДЕ            , если установлен → ДЕ (обмен с МД)

***************************************************
* ВХМЛ – ВХОД В ОБРАБОТКУ ОБМЕНА С МЛ
* ОТМЕЧАЕТ ЗАНЯТОСТЬ И ЗАДЕРЖИВАЕТ ОБМЕН, ЕСЛИ НУЖНО
***************************************************
ВХМЛ	сч	ШКМЛ(М16)     , взять шкалу занятости МЛ
	мод	НЗАД          , по текущей задаче
	или	E48-1         , установить бит занятости
	зп	ШКМЛ(М16)     , сохранить шкалу
	сч	ШЗЗОБМ        , проверить шкалу задержки обмена
	пе	НЕЛЬ          , если не пусто → отложить
	сч	E40           , установить флаг задержки
	зп	ШЗЗОБМ
	уиа	ВХОДМЛ(М16)   , адрес возврата для обработчика МЛ
	счи	М16
	зп	ИПЗМЛ+3       , сохранить в ИПЗ МЛ
	сч	E39           , запросить прерывание по МЛ
	пб	ПРОГР         , активировать обработку
***************************************************
* ЭКП – НАЧАЛО ОБРАБОТКИ ПРЕРЫВАНИЯ ОТ МЛ?
***************************************************
ЭКП	счи	М16           , сохранить М16
	зп	И16
	счрж	'37'          , сохранить РАУ
	или	П30           , установить бит 30
	или	E3            , установить бит 3
	зп	РК            , сохранить в РК
	сч	E15           , проверить бит 15
	пв	ПЕЭКС(М16)    , проверка перехвата экстракода
	мод	ГУС           , проверить 33-е слово ИПЗ
	сч	33
	и	E15           , бит 15
	по	тв210         , если 0 → тв210 (отложить)
	пб	надо          , иначе → надо (продолжить)

***************************************************
* ДЛЯМБ – ПОДГОТОВКА К ОБМЕНУ С МБ
* ФОРМИРУЕТ НОМЕР НАПРАВЛЕНИЯ И УСТРОЙСТВА, ПРОВЕРЯЕТ ФЛАГИ
***************************************************
ДЛЯМБ	сч	ФКУСМБ        , загрузить КУС МБ
	сбр	НМБТР         , очистить маску тракта?
	сда	64+37         , сдвиг для выделения номера МБ/направления
	вч	E9            , вычитание 9
	слц	E1            , добавление 1
	уи	М6            , М6 = номер направления/устройства
	сч	ФКУСМБ
	уиа	'3'           , разрешить прерывания
	и	E18           , проверить бит 18 (признак чтения?)
	пе	фи56          , если установлен → фи56 (обработка ошибок?)
	сч	ФКУСМБ
	и	E19           , проверить бит 19
	по	фи56          , если 0 → фи56
	пб	фи5           , иначе → фи5 (продолжение обмена)
***************************************************
* СИЗ – ВХОД ПОСЛЕ ОБРАБОТКИ МЛ?
* ВОССТАНАВЛИВАЕТ КУС, ПРОВЕРЯЕТ ОЧЕРЕДЬ ЗАКАЗОВ
***************************************************
СИЗ	сч	ТУС-1(М17)    , загрузить ГУС задачи
	уи	М15           , адрес ИПЗ
	зп	ИПЗМЛ+9       , сохранить в ИПЗ МЛ
	сч	(М15)         , загрузить первое слово ИПЗ (СМ)
	зп	ФКУС          , сохранить как флаговый КУС
	и	E5            , проверить бит 5
	пе	нумб          , если установлен → нумб (ненулевой?)
	сч	СЧЗАК         , счётчик заказов
	слц	МИН17         , добавить мин. значение
	по	НИС           , если 0 → НИС (нет заказов)
нумб	сч	шфзобм        , шкала ожидания обмена
	и	E48-1(М17)    , маска текущей задачи
	по	нук           , если 0 → нук
	сч	2(М15)        , загрузить 2-е слово ИПЗ
нук	зп	РМР           , сохранить в РМР (адрес буфера)
	сч	ФКУС          , загрузить КУС
	уиа	(М10)         , М10 = 0 (МЛ)
	пб	длядс         , перейти к диспетчеру длядс

***************************************************
* физо5 – СОХРАНЕНИЕ ФКУСМБ И ПОДГОТОВКА К ДИСПЕТЧЕРУ
***************************************************
физо5	зп	ФКУСМБ        , сохранить КУС МБ
	сда	64+2          , выделить 2-й разряд (тип обмена)
	и	E1            , оставить только бит 1
	уи	М5            , М5 = тип обмена (0 или 1)
	сч	ФКУСМБ
	уиа	1(М10)        , М10 = 1 (МБ)
***************************************************
* длядс – ДИСПЕТЧЕР ВЫЗОВА ДИСКОВ
* В ЗАВИСИМОСТИ ОТ М10 ПЕРЕХОДИТ НА ДЛЯМБ (МБ) ИЛИ длямл (МЛ)
***************************************************
длядс	уиа	'2003'        , блокировка прерываний
	сбр	ЛИСТА         , очистить старшие разряды (обнуление 37-го?)
	сда	64+7          , сдвиг для выделения номера листа
	зп	ФКУСА(М10)    , сохранить в ФКУСА (0 для МЛ, 1 для МБ)
	сч	ФКУС(М10)     , взять флаговый КУС
	или	ЛИСТА         , установить бит "ЛИСТ"
	нтж	ЛИСТА         , сбросить этот бит
	или	E17           , установить 17-й разряд
	зп	ФКУС(М10)     , сохранить обновлённый КУС
	сч	РМР           , взять РМР (адрес/смещение)
	или	ФКУСА(М10)    , добавить смещение
	зп	ФКУСА(М10)    , полный адрес буфера
	пио	длямл(М10)    , если М10=0 → перейти на обмен с МЛ
	слиа	-1(М10)       , уменьшить М10 (теперь 0)
	пио	ДЛЯМБ(М10)    , если стало 0 → обмен с МБ
	сч	ряв           , проверить флаг РЯВ (режим?)
	по	дб            , если 0 → дб (диски)
	сч	ФКУСД         , работа с МД
	нтж	E17           , инвертировать 17-й разряд
	зп	ФКУСД         , сохранить
дб	сч	ФКУСД         , загрузка флагового КУС диска
	сбр	мстр          , очистить маску структуры
	сда	64+43         , сдвиг для выделения номера задачи
	или	ФКУСАД        , добавить адрес
	зп	ФКУСАД        , сохранить полный КУС диска
	пб	ФЗ9А          , перейти к планировщику дисков

***************************************************
* длямл – ПЕРЕХОД К ОБРАБОТКЕ ОБМЕНА С МЛ
* УСТАНАВЛИВАЕТ ПРИЗНАКИ И ПЕРЕДАЁТ УПРАВЛЕНИЕ НА ФЗО3А/НЕБЕЗ
***************************************************
длямл	сч	ФКУС          , взять флаговый КУС МЛ
	уиа	(М2)          , М2=0 (не общая МЛ)
	уиа	(М17)         , М17=0
	и	E2            , проверить 2-й разряд (подвод без ответа?)
	по	НЕБЕЗ         , если 0 → НЕБЕЗ (с ответом)
	сч	ФКУС          , подвод МЛ без ответа
	сда	64+42         , выделить номер задачи
	уи	М13           , сохранить в М13
	сч	ФКУС
	и	E17           , проверить 17-й разряд
	по	МЛФ           , если 0 → МЛФ (пользовательская задача)
	сч	E48-1(М13)    , маска задачи для служебных
	уиа	НЕБЕЗ(М15)    , адрес возврата НЕБЕЗ
	пб	ВШГ           , активировать через ВШГ (шлюз готовности)
МЛФ	сч	E48-1(М13)    , маска задачи для пользовательских
	пв	ВШГП(М15)     , активировать через ВШГП
НЕБЕЗ	уиа	'3'           , разрешить прерывания
	сч	П30           , маска 30₈
	или	П3            , маска 3₈
	и	ФКУС          , проверить соответствующие биты
	пе	МВ            , если установлены → МВ (подвод с заказом)
	сч	ФКУС
	и	E18           , проверить 18-й разряд (чтение?)
	пб	ФЗО3А         , перейти к выполнению обмена с МЛ
