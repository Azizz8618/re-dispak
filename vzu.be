	сч	E1          , код 1 – запрос разметки
	зп	ШЗРАЗМ(М16) , задача поставлена в ожидание
* разметки
	уиа	(М16)       , М16 = 0
	пб	ЭКВЫХ       , возврат из экстракода
рзмд	уиа	1(М16)      , М16 = 1 (признак разметки МД)
	пб	рзм         , общая процедура разметки

АЦПУ	зп	И16         , сохранить аргумент (команду АЦПУ)
	счрж	'37'        , сохранить РАУ
	или	E5
	или	E3
	зп	РК
	сч	НЗАД        , проверить тип задачи
	и	E48         , 48-й разряд (0 – служебная)
	по	неон        , служебная → пропуск проверок
	мод	ГУС         , взять 50-е слово ИПЗ (события)
	сч	62
	мод	ГУС         , избыточная модификация
	или	E46         , добавить бит 46 (событие Э64)
	и	E43         , проверить бит 43 (доступ к АЦПУ)
	пе	мими        , есть доступ → спецобработка
	мод	ГУС         , взять 27-е слово ИПЗ (режимы)
	сч	33
	и	E12         , бит 12 (разрешение на АЦПУ)
	пб	неон        , в любом случае продолжить
	пб	неон        , заглушка
мими	сч	E12         , загрузить бит 12
	пв	ПЕЭКС(М16)  , проверить перехват Э64
неон	сч	E41         , код нерезидента E41 (Э64)
	пб	ТВ40        , активировать нерезидент

