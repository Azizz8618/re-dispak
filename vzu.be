        сч      ИНФСЛП(М16)    , инф. слово обмена ИПЗ
        слц     E16         , добавить 16 (сдвиг для проверки
* бита 18)
        и       E18         , выделить бит 18
        по      анво2       , если 0 → переход к анво2 (МБ)
        сч      ИНФСЛП(М16)    , иначе проверить разметку МД
        и       Е37Е36      , маска 37–36 (разметка)
        нтж     Е37Е36
        пе      анво2       , если не равно → анво2 (не разм.)
        сч      E32         , установить признак "МД 3.0"
        или     40(М16)     , в 32-е слово ИПЗ (40₈)
        зп      40(М16)
анво2   сч      40(М16)     , загрузить 32-е слово ИПЗ
        зп      СМ
        сч      ИНФСЛП(М16)    , проверить 39-й разряд в 40-м слове
        и       E39
        по      ддуб        , если 0 → ддуб (дублирование)
        сч      ИНФСЛП(М16)    , проверить 40-й разряд
        и       E40
        пе      гаш36       , если 1 → гашение 36
        сч      27(М16)     , проверить 23-е слово ИПЗ (27₈)
        и       E28         , бит 28
        по      заппар      , если 0 → заппар (запись пары?)
гаш36   сч      ИНФСЛП(М16)    , снять биты 36–37
        или     Е37Е36
        нтж     Е37Е36
        зп      ИНФСЛП(М16)    , записать в 40-е слово ИПЗ
ддуб    сч      ИНФСЛП(М16)    , выделить номер операции
        сда     64+12
        и       П77
        зп      РМР
        слц     E4
        и       E6
        по      дд          , если 0 → дд (диски?)
        сч      СМ          , иначе проверить 59-е слово
        мод     РМР
        и       59
        по      дд          , если 0 → дд
АНДИ1   мод     ГУС         , установить бит E47 в 40-м слове
        сч      E48
        или     E47
        мод     ГУС
        зп      E48
        пб      анди2       , переход к анди2

пзз     сч      АСБОЙБ      , адрес обработчика сбоев
        уи      М33         , М33 = адрес возврата
        сч      ИВ25        , конфигурация прерывания
        пб      пз1         , перейти к пз1

дд      сч      41(М16)     , проверить 33-е слово ИПЗ (41₈)
        и       E2          , бит 2
        пе      пзз         , если установлен → пзз (авария?)
        счи     М32         , иначе сохранить адрес возврата
        уи      М33
        сч      ,           , СМ = 0
пз1     уи      М27         , М27 = 0
        сч      ИНФСЛП(М16)    , загрузить 40-е слово ИПЗ (E48)
        зп      СМ
